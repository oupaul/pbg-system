<% 
  // 在 EJS 中處理邏輯
  // 確保變數存在，如果不存在則使用預設值
  const localSettings = typeof settings !== 'undefined' ? settings : [];
  const localError = typeof error !== 'undefined' ? error : '';
  const localSuccess = typeof success !== 'undefined' ? success : '';
  
  const notificationDaysSetting = localSettings.find(s => s.setting_key === 'invoice_notification_days_before_month_end');
  const notificationEnabledSetting = localSettings.find(s => s.setting_key === 'invoice_notification_enabled');
  const idleTimeoutSetting = localSettings.find(s => s.setting_key === 'idle_timeout_minutes');
  const idleWarningSetting = localSettings.find(s => s.setting_key === 'idle_warning_minutes');
  const attachmentCleanupSetting = localSettings.find(s => s.setting_key === 'attachment_cleanup_retention_days');
  
  const notificationDaysValue = notificationDaysSetting ? notificationDaysSetting.setting_value : '6';
  const notificationEnabledValue = notificationEnabledSetting ? notificationEnabledSetting.setting_value : 'true';
  const idleTimeoutValue = idleTimeoutSetting ? idleTimeoutSetting.setting_value : '30';
  const idleWarningValue = idleWarningSetting ? idleWarningSetting.setting_value : '2';
  const attachmentCleanupValue = attachmentCleanupSetting ? attachmentCleanupSetting.setting_value : '30';
  
  const isNotificationEnabled = notificationEnabledValue === 'true';
  const notificationDaysDesc = notificationDaysSetting ? notificationDaysSetting.description : '當月剩餘天數少於或等於此值時開始顯示通知';
  const notificationEnabledDesc = notificationEnabledSetting ? notificationEnabledSetting.description : '是否啟用開票提醒通知功能';
  const idleTimeoutDesc = idleTimeoutSetting ? idleTimeoutSetting.description : '使用者閒置自動登出時間（分鐘），0 表示停用';
  const idleWarningDesc = idleWarningSetting ? idleWarningSetting.description : '閒置登出前的警告時間（分鐘）';
  
  // 構建 body HTML
  let bodyHtml = '<div class="d-flex justify-content-between align-items-center mb-4">';
  bodyHtml += '  <h2><i class="bi bi-gear"></i> 系統設定</h2>';
  bodyHtml += '</div>';

  if (localError) {
    bodyHtml += '<div class="alert alert-danger alert-dismissible fade show" role="alert">';
    bodyHtml += '  <i class="bi bi-exclamation-circle"></i> ' + localError;
    bodyHtml += '  <button type="button" class="btn-close" data-bs-dismiss="alert"></button>';
    bodyHtml += '</div>';
  }

  if (localSuccess) {
    bodyHtml += '<div class="alert alert-success alert-dismissible fade show" role="alert">';
    bodyHtml += '  <i class="bi bi-check-circle"></i> ' + localSuccess;
    bodyHtml += '  <button type="button" class="btn-close" data-bs-dismiss="alert"></button>';
    bodyHtml += '</div>';
  }

  bodyHtml += '<div class="card">';
  bodyHtml += '  <div class="card-header bg-primary text-white">';
  bodyHtml += '    <h5 class="mb-0"><i class="bi bi-bell"></i> 開票提醒通知設定</h5>';
  bodyHtml += '  </div>';
  bodyHtml += '  <div class="card-body">';
  bodyHtml += '    <form method="POST" action="/settings/bulk-update" id="settingsForm">';
  bodyHtml += '      <div class="row g-3">';
  bodyHtml += '        <div class="col-md-6">';
  bodyHtml += '          <label for="invoice_notification_days_before_month_end" class="form-label">';
  bodyHtml += '            <i class="bi bi-calendar-event"></i> <strong>通知提前天數</strong>';
  bodyHtml += '          </label>';
  bodyHtml += '          <div class="input-group">';
  bodyHtml += '            <input type="number" class="form-control" id="invoice_notification_days_before_month_end" name="invoice_notification_days_before_month_end" value="' + notificationDaysValue + '" min="0" max="30" required>';
  bodyHtml += '            <span class="input-group-text">天</span>';
  bodyHtml += '          </div>';
  bodyHtml += '          <div class="form-text">' + notificationDaysDesc + '<br>';
  bodyHtml += '            <small class="text-muted">例如：設定為 <strong>6</strong> 表示倒數第 <strong>7</strong> 天開始提醒（當月剩餘 ≤ 6 天時顯示）</small>';
  bodyHtml += '          </div>';
  bodyHtml += '          <div class="alert alert-info mt-2 mb-0">';
  bodyHtml += '            <small>';
  bodyHtml += '              <i class="bi bi-info-circle"></i> <strong>建議值：</strong>';
  bodyHtml += '              <ul class="mb-0">';
  bodyHtml += '                <li><strong>6 天</strong>：倒數第 7 天開始（推薦，預設值）</li>';
  bodyHtml += '                <li><strong>9 天</strong>：倒數第 10 天開始（提前更多）</li>';
  bodyHtml += '                <li><strong>2 天</strong>：倒數第 3 天開始（緊急提醒）</li>';
  bodyHtml += '              </ul>';
  bodyHtml += '            </small>';
  bodyHtml += '          </div>';
  bodyHtml += '        </div>';
  bodyHtml += '        <div class="col-md-6">';
  bodyHtml += '          <label class="form-label">';
  bodyHtml += '            <i class="bi bi-toggle-on"></i> <strong>通知功能狀態</strong>';
  bodyHtml += '          </label>';
  bodyHtml += '          <div class="form-check form-switch">';
  bodyHtml += '            <input class="form-check-input" type="checkbox" id="invoice_notification_enabled" name="invoice_notification_enabled" value="true" ' + (isNotificationEnabled ? 'checked' : '') + '>';
  bodyHtml += '            <label class="form-check-label" for="invoice_notification_enabled">' + (isNotificationEnabled ? '已啟用' : '已停用') + '</label>';
  bodyHtml += '          </div>';
  bodyHtml += '          <div class="form-text">' + notificationEnabledDesc + '</div>';
  bodyHtml += '        </div>';
  bodyHtml += '      </div>';
  bodyHtml += '      <hr class="my-4">';
  bodyHtml += '      <div class="d-flex justify-content-between align-items-center">';
  bodyHtml += '        <div class="text-muted small"><i class="bi bi-info-circle"></i> 設定變更後會立即生效，無需重啟服務</div>';
  bodyHtml += '        <div>';
  bodyHtml += '          <button type="submit" class="btn btn-primary"><i class="bi bi-save"></i> 儲存設定</button>';
  bodyHtml += '          <a href="/" class="btn btn-secondary"><i class="bi bi-x-circle"></i> 取消</a>';
  bodyHtml += '        </div>';
  bodyHtml += '      </div>';
  bodyHtml += '    </form>';
  bodyHtml += '  </div>';
  bodyHtml += '</div>';
  
  // 閒置登出設定卡片
  bodyHtml += '<div class="card mt-4">';
  bodyHtml += '  <div class="card-header bg-primary text-white">';
  bodyHtml += '    <h5 class="mb-0"><i class="bi bi-clock-history"></i> 閒置自動登出設定</h5>';
  bodyHtml += '  </div>';
  bodyHtml += '  <div class="card-body">';
  bodyHtml += '    <form method="POST" action="/settings/bulk-update" id="idleSettingsForm">';
  bodyHtml += '      <div class="row g-3">';
  bodyHtml += '        <div class="col-md-6">';
  bodyHtml += '          <label for="idle_timeout_minutes" class="form-label">';
  bodyHtml += '            <i class="bi bi-hourglass-split"></i> <strong>閒置時間（分鐘）</strong>';
  bodyHtml += '          </label>';
  bodyHtml += '          <div class="input-group">';
  bodyHtml += '            <input type="number" class="form-control" id="idle_timeout_minutes" name="idle_timeout_minutes" value="' + idleTimeoutValue + '" min="0" max="480" required>';
  bodyHtml += '            <span class="input-group-text">分鐘</span>';
  bodyHtml += '          </div>';
  bodyHtml += '          <div class="form-text">' + idleTimeoutDesc + '</div>';
  bodyHtml += '          <div class="alert alert-info mt-2 mb-0">';
  bodyHtml += '            <small>';
  bodyHtml += '              <i class="bi bi-info-circle"></i> <strong>建議值：</strong>';
  bodyHtml += '              <ul class="mb-0">';
  bodyHtml += '                <li><strong>30 分鐘</strong>：標準設定（推薦）</li>';
  bodyHtml += '                <li><strong>60 分鐘</strong>：較寬鬆的時間限制</li>';
  bodyHtml += '                <li><strong>15 分鐘</strong>：更嚴格的安全性</li>';
  bodyHtml += '                <li><strong>0 分鐘</strong>：停用閒置登出功能</li>';
  bodyHtml += '              </ul>';
  bodyHtml += '            </small>';
  bodyHtml += '          </div>';
  bodyHtml += '        </div>';
  bodyHtml += '        <div class="col-md-6">';
  bodyHtml += '          <label for="idle_warning_minutes" class="form-label">';
  bodyHtml += '            <i class="bi bi-exclamation-triangle"></i> <strong>警告提前時間（分鐘）</strong>';
  bodyHtml += '          </label>';
  bodyHtml += '          <div class="input-group">';
  bodyHtml += '            <input type="number" class="form-control" id="idle_warning_minutes" name="idle_warning_minutes" value="' + idleWarningValue + '" min="1" max="10" required>';
  bodyHtml += '            <span class="input-group-text">分鐘</span>';
  bodyHtml += '          </div>';
  bodyHtml += '          <div class="form-text">' + idleWarningDesc + '</div>';
  bodyHtml += '          <div class="alert alert-warning mt-2 mb-0">';
  bodyHtml += '            <small>';
  bodyHtml += '              <i class="bi bi-lightbulb"></i> <strong>說明：</strong><br>';
  bodyHtml += '              在自動登出前 <strong>' + idleWarningValue + '</strong> 分鐘會顯示警告對話框，<br>';
  bodyHtml += '              讓使用者有機會延長會話時間或立即登出。';
  bodyHtml += '            </small>';
  bodyHtml += '          </div>';
  bodyHtml += '        </div>';
  bodyHtml += '      </div>';
  bodyHtml += '      <hr class="my-4">';
  bodyHtml += '      <div class="d-flex justify-content-between align-items-center">';
  bodyHtml += '        <div class="text-muted small">';
  bodyHtml += '          <i class="bi bi-shield-check"></i> 閒置登出可提升系統安全性，防止他人未經授權存取';
  bodyHtml += '        </div>';
  bodyHtml += '        <div>';
  bodyHtml += '          <button type="submit" class="btn btn-primary"><i class="bi bi-save"></i> 儲存設定</button>';
  bodyHtml += '          <a href="/" class="btn btn-secondary"><i class="bi bi-x-circle"></i> 取消</a>';
  bodyHtml += '        </div>';
  bodyHtml += '      </div>';
  bodyHtml += '    </form>';
  bodyHtml += '  </div>';
  bodyHtml += '</div>';
  
  // 專案附件清理設定卡片
  bodyHtml += '<div class="card mt-4">';
  bodyHtml += '  <div class="card-header bg-secondary text-white">';
  bodyHtml += '    <h5 class="mb-0"><i class="bi bi-paperclip"></i> 專案附件清理設定</h5>';
  bodyHtml += '  </div>';
  bodyHtml += '  <div class="card-body">';
  bodyHtml += '    <form method="POST" action="/settings/bulk-update">';
  bodyHtml += '      <div class="row g-3">';
  bodyHtml += '        <div class="col-md-6">';
  bodyHtml += '          <label for="attachment_cleanup_retention_days" class="form-label">';
  bodyHtml += '            <i class="bi bi-calendar-x"></i> <strong>軟刪除後保留天數</strong>';
  bodyHtml += '          </label>';
  bodyHtml += '          <div class="input-group">';
  bodyHtml += '            <input type="number" class="form-control" id="attachment_cleanup_retention_days" name="attachment_cleanup_retention_days" value="' + attachmentCleanupValue + '" min="0" max="365">';
  bodyHtml += '            <span class="input-group-text">天</span>';
  bodyHtml += '          </div>';
  bodyHtml += '          <div class="form-text">專案附件「刪除」後改為軟刪除，超過此天數將由定期清理腳本永久刪除檔案與記錄。<strong>0 = 不自動清理</strong>（僅能手動執行清理腳本）。</div>';
  bodyHtml += '          <div class="alert alert-info mt-2 mb-0">';
  bodyHtml += '            <small><i class="bi bi-info-circle"></i> 建議以 cron 每日執行：<code>0 2 * * * cd /opt/您的專案目錄 && npm run cleanup:attachments</code></small>';
  bodyHtml += '          </div>';
  bodyHtml += '        </div>';
  bodyHtml += '      </div>';
  bodyHtml += '      <hr class="my-4">';
  bodyHtml += '      <button type="submit" class="btn btn-primary"><i class="bi bi-save"></i> 儲存設定</button>';
  bodyHtml += '    </form>';
  bodyHtml += '  </div>';
  bodyHtml += '</div>';
  
  bodyHtml += '<div class="card mt-4">';
  bodyHtml += '  <div class="card-header bg-light">';
  bodyHtml += '    <h5 class="mb-0"><i class="bi bi-question-circle"></i> 設定說明</h5>';
  bodyHtml += '  </div>';
  bodyHtml += '  <div class="card-body">';
  bodyHtml += '    <h6><i class="bi bi-bell-fill text-warning"></i> 開票提醒通知機制</h6>';
  bodyHtml += '    <ul>';
  bodyHtml += '      <li><strong>通知條件：</strong>同時滿足以下條件才會顯示通知';
  bodyHtml += '        <ul>';
  bodyHtml += '          <li>當月剩餘天數 ≤ 設定的提前天數</li>';
  bodyHtml += '          <li>專案的「預計開票年月」= 當前月份</li>';
  bodyHtml += '          <li>專案狀態 = 「未結案」</li>';
  bodyHtml += '          <li>通知功能已啟用</li>';
  bodyHtml += '        </ul>';
  bodyHtml += '      </li>';
  bodyHtml += '      <li><strong>通知位置：</strong>儀表板（首頁）頂部會顯示黃色警告框</li>';
  bodyHtml += '      <li><strong>通知內容：</strong>顯示符合條件的專案列表，包含專案編號、名稱、金額、未開發票金額等資訊</li>';
  bodyHtml += '    </ul>';
  bodyHtml += '    <h6 class="mt-3"><i class="bi bi-calendar3 text-primary"></i> 提前天數計算範例</h6>';
  bodyHtml += '    <div class="table-responsive">';
  bodyHtml += '      <table class="table table-sm table-bordered">';
  bodyHtml += '        <thead class="table-light"><tr><th>設定值</th><th>通知開始時間</th><th>適用情境</th></tr></thead>';
  bodyHtml += '        <tbody>';
  bodyHtml += '          <tr><td><strong>6 天</strong></td><td>倒數第 7 天</td><td>推薦設定，給業務足夠時間處理</td></tr>';
  bodyHtml += '          <tr><td><strong>9 天</strong></td><td>倒數第 10 天</td><td>提前更多，適合需要較長作業時間的情況</td></tr>';
  bodyHtml += '          <tr><td><strong>2 天</strong></td><td>倒數第 3 天</td><td>緊急提醒，僅在月底前幾天提醒</td></tr>';
  bodyHtml += '        </tbody>';
  bodyHtml += '      </table>';
  bodyHtml += '    </div>';
  bodyHtml += '    <h6 class="mt-4"><i class="bi bi-clock-history text-warning"></i> 閒置自動登出機制</h6>';
  bodyHtml += '    <ul>';
  bodyHtml += '      <li><strong>觸發條件：</strong>使用者在設定的時間內沒有任何操作（滑鼠移動、鍵盤輸入、點擊等）</li>';
  bodyHtml += '      <li><strong>警告機制：</strong>在達到閒置時間前會顯示警告對話框';
  bodyHtml += '        <ul>';
  bodyHtml += '          <li>倒數計時顯示剩餘時間</li>';
  bodyHtml += '          <li>可選擇「繼續使用」延長會話時間</li>';
  bodyHtml += '          <li>可選擇「立即登出」主動登出</li>';
  bodyHtml += '        </ul>';
  bodyHtml += '      </li>';
  bodyHtml += '      <li><strong>自動登出：</strong>如果警告期間仍無操作，系統會自動登出並返回登入頁面</li>';
  bodyHtml += '      <li><strong>安全性：</strong>此功能可防止他人在使用者離開時未經授權存取系統</li>';
  bodyHtml += '      <li><strong>停用方式：</strong>將「閒置時間」設定為 0 即可停用此功能</li>';
  bodyHtml += '    </ul>';
  bodyHtml += '    <div class="alert alert-warning">';
  bodyHtml += '      <i class="bi bi-exclamation-triangle"></i> <strong>注意：</strong>';
  bodyHtml += '      設定變更後，需重新整理頁面才會生效。建議設定完成後請所有使用者重新整理瀏覽器。';
  bodyHtml += '    </div>';
  bodyHtml += '  </div>';
  bodyHtml += '</div>';
  bodyHtml += '<script>';
  bodyHtml += 'document.addEventListener("DOMContentLoaded", function() {';
  bodyHtml += '  const enabledCheckbox = document.getElementById("invoice_notification_enabled");';
  bodyHtml += '  if (enabledCheckbox) {';
  bodyHtml += '    enabledCheckbox.addEventListener("change", function() {';
  bodyHtml += '      const label = this.nextElementSibling;';
  bodyHtml += '      label.textContent = this.checked ? "已啟用" : "已停用";';
  bodyHtml += '    });';
  bodyHtml += '  }';
  bodyHtml += '  const settingsForm = document.getElementById("settingsForm");';
  bodyHtml += '  if (settingsForm) {';
  bodyHtml += '    settingsForm.addEventListener("submit", function(e) {';
  bodyHtml += '      if (enabledCheckbox && !enabledCheckbox.checked) {';
  bodyHtml += '        const hiddenInput = document.createElement("input");';
  bodyHtml += '        hiddenInput.type = "hidden";';
  bodyHtml += '        hiddenInput.name = "invoice_notification_enabled";';
  bodyHtml += '        hiddenInput.value = "false";';
  bodyHtml += '        this.appendChild(hiddenInput);';
  bodyHtml += '      }';
  bodyHtml += '    });';
  bodyHtml += '  }';
  bodyHtml += '});';
  bodyHtml += '</script>';
%>

<%- include('../layout', { title: '系統設定', body: bodyHtml }) %>
