  bodyHtml += '  </div>';
  bodyHtml += '</div>';

  bodyHtml += '<div class="card mt-4">';
  bodyHtml += '  <div class="card-header bg-light">';
  bodyHtml += '    <h5 class="mb-0"><i class="bi bi-question-circle"></i> 設定說明</h5>';
  bodyHtml += '  </div>';
  bodyHtml += '  <div class="card-body">';
  bodyHtml += '    <h6><i class="bi bi-bell-fill text-warning"></i> 開票提醒通知機制</h6>';
  bodyHtml += '    <ul>';
  bodyHtml += '      <li><strong>通知條件：</strong>同時滿足以下條件才會顯示通知';
  bodyHtml += '        <ul>';
  bodyHtml += '          <li>當月剩餘天數 ≤ 設定的提前天數</li>';
  bodyHtml += '          <li>專案的「預計開票年月」= 當前月份</li>';
  bodyHtml += '          <li>專案狀態 = 「未結案」</li>';
  bodyHtml += '          <li>通知功能已啟用</li>';
  bodyHtml += '        </ul>';
  bodyHtml += '      </li>';
  bodyHtml += '      <li><strong>通知位置：</strong>儀表板（首頁）頂部會顯示黃色警告框</li>';
  bodyHtml += '      <li><strong>通知內容：</strong>顯示符合條件的專案列表，包含專案編號、名稱、金額、未開發票金額等資訊</li>';
  bodyHtml += '    </ul>';
  bodyHtml += '    <h6 class="mt-3"><i class="bi bi-calendar3 text-primary"></i> 提前天數計算範例</h6>';
  bodyHtml += '    <div class="table-responsive">';
  bodyHtml += '      <table class="table table-sm table-bordered">';
  bodyHtml += '        <thead class="table-light"><tr><th>設定值</th><th>通知開始時間</th><th>適用情境</th></tr></thead>';
  bodyHtml += '        <tbody>';
  bodyHtml += '          <tr><td><strong>6 天</strong></td><td>倒數第 7 天</td><td>推薦設定，給業務足夠時間處理</td></tr>';
  bodyHtml += '          <tr><td><strong>9 天</strong></td><td>倒數第 10 天</td><td>提前更多，適合需要較長作業時間的情況</td></tr>';
  bodyHtml += '          <tr><td><strong>2 天</strong></td><td>倒數第 3 天</td><td>緊急提醒，僅在月底前幾天提醒</td></tr>';
  bodyHtml += '        </tbody>';
  bodyHtml += '      </table>';
  bodyHtml += '    </div>';
  bodyHtml += '    <h6 class="mt-4"><i class="bi bi-clock-history text-warning"></i> 閒置自動登出機制</h6>';
  bodyHtml += '    <ul>';
  bodyHtml += '      <li><strong>觸發條件：</strong>使用者在設定的時間內沒有任何操作（滑鼠移動、鍵盤輸入、點擊等）</li>';
  bodyHtml += '      <li><strong>警告機制：</strong>在達到閒置時間前會顯示警告對話框';
  bodyHtml += '        <ul>';
  bodyHtml += '          <li>倒數計時顯示剩餘時間</li>';
  bodyHtml += '          <li>可選擇「繼續使用」延長會話時間</li>';
  bodyHtml += '          <li>可選擇「立即登出」主動登出</li>';
  bodyHtml += '        </ul>';
  bodyHtml += '      </li>';
  bodyHtml += '      <li><strong>自動登出：</strong>如果警告期間仍無操作，系統會自動登出並返回登入頁面</li>';
  bodyHtml += '      <li><strong>安全性：</strong>此功能可防止他人在使用者離開時未經授權存取系統</li>';
  bodyHtml += '      <li><strong>停用方式：</strong>將「閒置時間」設定為 0 即可停用此功能</li>';
  bodyHtml += '    </ul>';
  bodyHtml += '    <div class="alert alert-warning">';
  bodyHtml += '      <i class="bi bi-exclamation-triangle"></i> <strong>注意：</strong>';
  bodyHtml += '      設定變更後，需重新整理頁面才會生效。建議設定完成後請所有使用者重新整理瀏覽器。';
  bodyHtml += '    </div>';
  bodyHtml += '  </div>';
  bodyHtml += '</div>';
  bodyHtml += '<script>';
  bodyHtml += 'document.addEventListener("DOMContentLoaded", function() {';
  bodyHtml += '  const enabledCheckbox = document.getElementById("invoice_notification_enabled");';
  bodyHtml += '  if (enabledCheckbox) {';
  bodyHtml += '    enabledCheckbox.addEventListener("change", function() {';
  bodyHtml += '      const label = this.nextElementSibling;';
  bodyHtml += '      label.textContent = this.checked ? "已啟用" : "已停用";';
  bodyHtml += '    });';
  bodyHtml += '  }';
  bodyHtml += '  const settingsForm = document.getElementById("settingsForm");';
  bodyHtml += '  if (settingsForm) {';
  bodyHtml += '    settingsForm.addEventListener("submit", function(e) {';
  bodyHtml += '      if (enabledCheckbox && !enabledCheckbox.checked) {';
  bodyHtml += '        const hiddenInput = document.createElement("input");';
  bodyHtml += '        hiddenInput.type = "hidden";';
  bodyHtml += '        hiddenInput.name = "invoice_notification_enabled";';
  bodyHtml += '        hiddenInput.value = "false";';
  bodyHtml += '        this.appendChild(hiddenInput);';
  bodyHtml += '      }';
  bodyHtml += '    });';
  bodyHtml += '  }';
  bodyHtml += '';
  bodyHtml += '  // 通用處理：switch 開關 checkbox（未勾選時補送 false）與空白密碼/token 欄位（留空則不覆蓋既有值）';
  bodyHtml += '  function wireSwitchForm(formId, checkboxIds, secretIds) {';
  bodyHtml += '    const form = document.getElementById(formId);';
  bodyHtml += '    if (!form) return;';
  bodyHtml += '    checkboxIds.forEach(function (id) {';
  bodyHtml += '      const cb = document.getElementById(id);';
  bodyHtml += '      if (!cb) return;';
  bodyHtml += '      cb.addEventListener("change", function () {';
  bodyHtml += '        const label = this.nextElementSibling;';
  bodyHtml += '        if (label && label.tagName === "LABEL") label.textContent = this.checked ? "已啟用" : "已停用";';
  bodyHtml += '      });';
  bodyHtml += '    });';
  bodyHtml += '    form.addEventListener("submit", function () {';
  bodyHtml += '      checkboxIds.forEach(function (id) {';
  bodyHtml += '        const cb = document.getElementById(id);';
  bodyHtml += '        if (cb && !cb.checked) {';
  bodyHtml += '          const hidden = document.createElement("input");';
  bodyHtml += '          hidden.type = "hidden";';
  bodyHtml += '          hidden.name = cb.name;';
  bodyHtml += '          hidden.value = "false";';
  bodyHtml += '          form.appendChild(hidden);';
  bodyHtml += '        }';
  bodyHtml += '      });';
  bodyHtml += '      (secretIds || []).forEach(function (id) {';
  bodyHtml += '        const input = document.getElementById(id);';
  bodyHtml += '        if (input && input.value.trim() === "") input.disabled = true;';
  bodyHtml += '      });';
  bodyHtml += '    });';
  bodyHtml += '  }';
  bodyHtml += '  wireSwitchForm("emailSettingsForm", ["email_notification_enabled", "smtp_secure"], ["smtp_password"]);';
  bodyHtml += '  wireSwitchForm("lineSettingsForm", ["line_notification_enabled"], ["line_channel_access_token", "line_channel_secret"]);';
  bodyHtml += '});';
  bodyHtml += '</script>';
%>

<%- include('../layout', { title: '系統設定', body: bodyHtml }) %>
