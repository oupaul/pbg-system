<!DOCTYPE html>
<html lang="zh-TW">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %> - <%= typeof pageTitleSuffix !== 'undefined' ? pageTitleSuffix : '業績獎金系統' %></title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css" rel="stylesheet">
  <link href="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/css/select2.min.css" rel="stylesheet" />
  <link href="https://cdn.jsdelivr.net/npm/select2-bootstrap-5-theme@1.3.0/dist/select2-bootstrap-5-theme.min.css" rel="stylesheet" />
  <link href="/css/style.css" rel="stylesheet">
</head>
<body>
  <%
    // 判斷導覽列連結是否對應目前頁面，供高亮當前所在頁面用
    function navActive(href) {
      const path = typeof currentPath !== 'undefined' ? currentPath : '';
      if (!path) return '';
      if (href === '/') return path === '/' ? 'active' : '';
      return path.indexOf(href) === 0 ? 'active' : '';
    }
  %>
  <nav class="navbar navbar-expand-lg navbar-dark bg-primary">
    <div class="container-fluid">
      <a class="navbar-brand" href="/">
        <i class="bi bi-calculator"></i> <%= typeof siteName !== 'undefined' ? siteName : '業績獎金系統' %>
      </a>
      <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
        <span class="navbar-toggler-icon"></span>
      </button>
      <div class="collapse navbar-collapse" id="navbarNav">
        <ul class="navbar-nav me-auto">
          <% if (typeof user !== 'undefined' && user && (user.role === 'admin' || user.role === 'user')) { %>
          <li class="nav-item">
            <a class="nav-link <%= navActive('/') %>" href="/"><i class="bi bi-house"></i> 首頁</a>
          </li>
          <% } %>
          <li class="nav-item">
            <a class="nav-link <%= navActive('/projects') %>" href="/projects"><i class="bi bi-folder"></i> 專案管理</a>
          </li>
          <% if (typeof user !== 'undefined' && user && (user.role === 'admin' || user.role === 'user')) { %>
          <li class="nav-item">
            <a class="nav-link <%= navActive('/project-templates') %>" href="/project-templates"><i class="bi bi-file-earmark-text"></i> 專案範本</a>
          </li>
          <% } %>
          <li class="nav-item">
            <a class="nav-link <%= navActive('/search') %>" href="/search"><i class="bi bi-search"></i> 搜尋</a>
          </li>
          <% if (typeof user !== 'undefined' && user && (user.role === 'admin' || user.role === 'user' || user.role === 'boss')) { %>
          <li class="nav-item">
            <a class="nav-link <%= navActive('/bonuses') %>" href="/bonuses"><i class="bi bi-currency-dollar"></i> 獎金管理</a>
          </li>
          <li class="nav-item">
            <a class="nav-link <%= navActive('/sales-performance') %>" href="/sales-performance"><i class="bi bi-graph-up"></i> 業務績效</a>
          </li>
          <% } %>
          <% if (typeof user !== 'undefined' && user && (user.role === 'admin' || user.role === 'user' || user.salesperson_id)) { %>
          <li class="nav-item">
            <a class="nav-link <%= navActive('/gross-profit') %>" href="/gross-profit"><i class="bi bi-pie-chart"></i> 毛利分析</a>
          </li>
          <% } %>
          <% if (typeof user !== 'undefined' && user && (user.role === 'admin' || user.role === 'user')) { %>
          <li class="nav-item">
            <a class="nav-link <%= navActive('/salespeople') %>" href="/salespeople"><i class="bi bi-people"></i> 業務管理</a>
          </li>
          <li class="nav-item">
            <a class="nav-link <%= navActive('/import-export') %>" href="/import-export"><i class="bi bi-arrow-left-right"></i> 匯入/匯出</a>
          </li>
          <li class="nav-item">
            <a class="nav-link <%= navActive('/audit-logs') %>" href="/audit-logs"><i class="bi bi-clock-history"></i> 修改記錄</a>
          </li>
          <li class="nav-item">
            <a class="nav-link <%= navActive('/recent-payments') %>" href="/recent-payments"><i class="bi bi-cash-coin"></i> 近期收款</a>
          </li>
          <% } %>
          <% if (typeof canEditCrm !== 'undefined' && canEditCrm) { %>
          <li class="nav-item">
            <a class="nav-link <%= navActive('/customers') %>" href="/customers"><i class="bi bi-building"></i> 客戶/廠商</a>
          </li>
          <li class="nav-item">
            <a class="nav-link <%= navActive('/pipelines') %>" href="/pipelines"><i class="bi bi-bullseye"></i> 潛在商機</a>
          </li>
          <% } %>
          <% if (typeof canDelete !== 'undefined' && canDelete) { %>
          <li class="nav-item">
            <a class="nav-link <%= navActive('/deletion-requests') %>" href="/deletion-requests">
              <i class="bi bi-shield-check"></i> 刪除審核
              <% if (typeof pendingDeletionCount !== 'undefined' && pendingDeletionCount > 0) { %>
                <span class="badge bg-danger"><%= pendingDeletionCount %></span>
              <% } %>
            </a>
          </li>
          <% } %>
          <% if (typeof user !== 'undefined' && user && user.role === 'admin') { %>
          <li class="nav-item">
            <a class="nav-link <%= navActive('/project-types') %>" href="/project-types"><i class="bi bi-tags"></i> 類型管理</a>
          </li>
          <li class="nav-item">
            <a class="nav-link <%= navActive('/report-groups') %>" href="/report-groups"><i class="bi bi-collection"></i> 報表群組</a>
          </li>
          <li class="nav-item">
            <a class="nav-link <%= navActive('/roles') %>" href="/roles"><i class="bi bi-shield-check"></i> 角色管理</a>
          </li>
          <li class="nav-item">
            <a class="nav-link <%= navActive('/settings') %>" href="/settings"><i class="bi bi-gear"></i> 系統設定</a>
          </li>
          <li class="nav-item">
            <a class="nav-link <%= navActive('/backup-restore') %>" href="/backup-restore"><i class="bi bi-archive"></i> 備份還原</a>
          </li>
          <li class="nav-item">
            <a class="nav-link <%= navActive('/health') %>" href="/health"><i class="bi bi-heart-pulse"></i> 系統健康</a>
          </li>
          <% } %>
        </ul>
        <% if (typeof user !== 'undefined' && user) { %>
          <ul class="navbar-nav">
            <li class="nav-item dropdown">
              <a class="nav-link dropdown-toggle" href="#" id="userDropdown" role="button" data-bs-toggle="dropdown">
                <i class="bi bi-person-circle"></i> <%= user.name || user.username %>
              </a>
              <ul class="dropdown-menu dropdown-menu-end">
                <li><h6 class="dropdown-header"><%= user.name || user.username %></h6></li>
                <li><hr class="dropdown-divider"></li>
                <li>
                  <a class="dropdown-item" href="/change-password">
                    <i class="bi bi-key"></i> 修改密碼
                  </a>
                </li>
                <% if (user.role === 'admin') { %>
                <li>
                  <a class="dropdown-item" href="/users">
                    <i class="bi bi-people"></i> 使用者管理
                  </a>
                </li>
                <% } %>
                <li><hr class="dropdown-divider"></li>
                <li>
                  <form method="POST" action="/logout" class="m-0">
                    <button type="submit" class="dropdown-item">
                      <i class="bi bi-box-arrow-right"></i> 登出
                    </button>
                  </form>
                </li>
              </ul>
            </li>
          </ul>
        <% } %>
      </div>
    </div>
  </nav>

  <main class="container-fluid py-4">
    <%- body %>
  </main>

  <footer class="footer mt-auto py-3 bg-light">
    <div class="container text-center">
      <span class="text-muted"><%= typeof locals.footerText !== 'undefined' ? locals.footerText : '專案開立發票業績認列獎金計算總表系統 ©' %> <%= new Date().getFullYear() %></span>
    </div>
  </footer>

  <!-- 必須先載入 jQuery，Select2 需要它 -->
  <script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>
  <!-- 然後載入 Bootstrap -->
  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
  <!-- 最後載入 Select2 -->
  <script src="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/js/select2.min.js"></script>
  <% if (typeof user !== 'undefined' && user) { %>
  <script>
    // 閒置登出配置（從伺服器傳遞到前端）
    window.idleConfig = {
      timeoutMinutes: <%= typeof idleTimeoutMinutes !== 'undefined' ? idleTimeoutMinutes : 30 %>,
      warningMinutes: <%= typeof idleWarningMinutes !== 'undefined' ? idleWarningMinutes : 2 %>
    };
  </script>
  <% } %>
  <script src="/js/main.js"></script>
</body>
</html>
