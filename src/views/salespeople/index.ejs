<%- include('../layout', { body: `
<div class="row mb-4">
  <div class="col">
    <h1 class="h3"><i class="bi bi-people"></i> 業務管理</h1>
  </div>
  <div class="col-auto d-flex gap-2">
    <form class="d-flex" method="get">
      <select name="year" class="form-select" onchange="this.form.submit()">
        <option value="all" ${selectedYear === 'all' ? 'selected' : ''}>全部年度</option>
        ${years.map(y => `<option value="${y}" ${y == selectedYear ? 'selected' : ''}>${y}</option>`).join('')}
      </select>
    </form>
    <button class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#newSalespersonModal">
      <i class="bi bi-plus-lg"></i> 新增業務
    </button>
  </div>
</div>

<div class="card">
  <div class="card-body p-0">
    <div class="table-responsive">
      <table class="table table-hover mb-0">
        <thead class="table-dark">
          <tr>
            <th>
              <a href="?${sortLinks.name}" class="text-white text-decoration-none">
                姓名${sortIcons.name}
              </a>
            </th>
            <th>
              <a href="?${sortLinks.status}" class="text-white text-decoration-none">
                狀態${sortIcons.status}
              </a>
            </th>
            <th class="text-center">
              <a href="?${sortLinks.project_count}" class="text-white text-decoration-none">
                專案數${sortIcons.project_count}
              </a>
            </th>
            <th class="text-end">
              <a href="?${sortLinks.total_amount}" class="text-white text-decoration-none">
                總金額${sortIcons.total_amount}
              </a>
            </th>
            <th class="text-end">
              <a href="?${sortLinks.lab_amount}" class="text-white text-decoration-none">
                食驗室${sortIcons.lab_amount}
              </a>
            </th>
            <th class="text-end">
              <a href="?${sortLinks.ad_amount}" class="text-white text-decoration-none">
                純廣${sortIcons.ad_amount}
              </a>
            </th>
            <th class="text-end">
              <a href="?${sortLinks.project_amount}" class="text-white text-decoration-none">
                專案${sortIcons.project_amount}
              </a>
            </th>
            <th class="text-center">儀表板獨立</th>
          </tr>
        </thead>
        <tbody>
          ${salespeople.map(s => `
              <tr onclick="location.href='/salespeople/${s.id}?year=${selectedYear === 'all' ? 'all' : selectedYear}'" style="cursor:pointer">
              <td><strong>${s.name}</strong></td>
              <td>
                <span class="badge bg-${s.status === 'active' ? 'success' : s.status === 'resigned' ? 'danger' : 'secondary'}">
                  ${s.status === 'active' ? '在職' : s.status === 'resigned' ? '離職' : '停用'}
                </span>
                ${s.resigned_date ? '<small class="text-muted ms-1">' + s.resigned_date + '</small>' : ''}
              </td>
              <td class="text-center">${s.project_count || 0}</td>
              <td class="text-end">$${(s.total_amount || 0).toLocaleString()}</td>
              <td class="text-end">$${(s.lab_amount || 0).toLocaleString()}</td>
              <td class="text-end">$${(s.ad_amount || 0).toLocaleString()}</td>
              <td class="text-end">$${(s.project_amount || 0).toLocaleString()}</td>
              <td class="text-center">${s.show_separate_dashboard ? '<span class="badge bg-info">是</span>' : '<span class="text-muted">-</span>'}</td>
            </tr>
          `).join('') || '<tr><td colspan="8" class="text-center text-muted py-3">尚無業務人員</td></tr>'}
        </tbody>
      </table>
    </div>
  </div>
</div>

<!-- 新增業務 Modal -->
<div class="modal fade" id="newSalespersonModal" tabindex="-1">
  <div class="modal-dialog">
    <div class="modal-content">
      <form action="/salespeople" method="POST">
        <div class="modal-header">
          <h5 class="modal-title">新增業務</h5>
          <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
        </div>
        <div class="modal-body">
          <div class="mb-3">
            <label class="form-label">姓名</label>
            <input type="text" name="name" class="form-control" required>
          </div>
          <div class="mb-3">
            <label class="form-label">狀態</label>
            <select name="status" class="form-select">
              <option value="active">在職</option>
              <option value="resigned">離職</option>
              <option value="suspended">停用</option>
            </select>
          </div>
        </div>
        <div class="modal-footer">
          <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">取消</button>
          <button type="submit" class="btn btn-primary">新增</button>
        </div>
      </form>
    </div>
  </div>
</div>
`}) %>
