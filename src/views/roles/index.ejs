<%
  function escapeHtml(str) {
    return (str || '').toString().replace(/</g, '&lt;').replace(/>/g, '&gt;');
  }
%>
<%- include('../layout', { body: `
<div class="container-fluid mt-4">
  <!-- 頁面標題 -->
  <div class="row mb-4">
    <div class="col-md-6">
      <h2><i class="bi bi-shield-check"></i> 角色管理</h2>
      <p class="text-muted">管理系統角色和權限設定</p>
    </div>
    <div class="col-md-6 text-end">
      <a href="/roles/new" class="btn btn-primary">
        <i class="bi bi-plus-circle"></i> 新增角色
      </a>
    </div>
  </div>

  <!-- 成功/錯誤訊息 -->
  ${success ? `
    <div class="alert alert-success alert-dismissible fade show" role="alert">
      <i class="bi bi-check-circle"></i> ${escapeHtml(success)}
      <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
  ` : ''}
  ${error ? `
    <div class="alert alert-danger alert-dismissible fade show" role="alert">
      <i class="bi bi-exclamation-triangle"></i> ${escapeHtml(error)}
      <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
  ` : ''}

  <!-- 篩選選項 -->
  <div class="card mb-4">
    <div class="card-body">
      <form method="GET" action="/roles" class="row g-3">
        <div class="col-md-4">
          <div class="form-check">
            <input class="form-check-input" type="checkbox" id="includeInactive" name="includeInactive" value="true" ${includeInactive ? 'checked' : ''} onchange="this.form.submit()">
            <label class="form-check-label" for="includeInactive">
              顯示已停用的角色
            </label>
          </div>
        </div>
      </form>
    </div>
  </div>

  <!-- 角色列表 -->
  <div class="card">
    <div class="card-body">
      ${roles.length === 0 ? `
        <div class="alert alert-info">
          <i class="bi bi-info-circle"></i> 目前沒有角色資料
        </div>
      ` : `
        <div class="table-responsive">
          <table class="table table-hover">
            <thead>
              <tr>
                <th style="width: 50px;">#</th>
                <th>角色代碼</th>
                <th>角色名稱</th>
                <th>描述</th>
                <th style="width: 100px;" class="text-center">使用人數</th>
                <th style="width: 100px;" class="text-center">狀態</th>
                <th style="width: 100px;" class="text-center">類型</th>
                <th style="width: 200px;" class="text-center">操作</th>
              </tr>
            </thead>
            <tbody>
              ${roles.map((role, index) => `
                <tr>
                  <td>${index + 1}</td>
                  <td><code>${role.role_key}</code></td>
                  <td>
                    <strong>${role.role_name}</strong>
                    ${role.is_system_role ? '<span class="badge bg-info ms-2">系統</span>' : ''}
                  </td>
                  <td class="text-muted">${role.description || '-'}</td>
                  <td class="text-center">
                    ${role.users_count > 0 ? `
                      <a href="/roles/${role.id}" class="badge bg-primary">${role.users_count} 人</a>
                    ` : `
                      <span class="text-muted">0 人</span>
                    `}
                  </td>
                  <td class="text-center">
                    ${role.is_active ? 
                      '<span class="badge bg-success">啟用</span>' : 
                      '<span class="badge bg-secondary">停用</span>'
                    }
                  </td>
                  <td class="text-center">
                    ${role.is_system_role ? 
                      '<span class="badge bg-info">系統角色</span>' : 
                      '<span class="badge bg-secondary">自訂角色</span>'
                    }
                  </td>
                  <td class="text-center">
                    <div class="btn-group btn-group-sm" role="group">
                      <a href="/roles/${role.id}" class="btn btn-outline-info" title="檢視詳情">
                        <i class="bi bi-eye"></i>
                      </a>
                      <a href="/roles/${role.id}/edit" class="btn btn-outline-primary" title="編輯">
                        <i class="bi bi-pencil"></i>
                      </a>
                      ${!role.is_system_role ? `
                        <button type="button" class="btn btn-outline-danger" onclick="deleteRole(${role.id}, '${role.role_name}')" title="刪除">
                          <i class="bi bi-trash"></i>
                        </button>
                      ` : `
                        <button type="button" class="btn btn-outline-secondary" disabled title="系統角色不可刪除">
                          <i class="bi bi-lock"></i>
                        </button>
                      `}
                    </div>
                  </td>
                </tr>
              `).join('')}
            </tbody>
          </table>
        </div>
      `}
    </div>
  </div>

  <!-- 權限說明 -->
  <div class="card mt-4">
    <div class="card-header bg-light">
      <h5 class="mb-0"><i class="bi bi-info-circle"></i> 權限說明</h5>
    </div>
    <div class="card-body">
      <div class="row">
        <div class="col-md-6">
          <h6>資料操作權限：</h6>
          <ul>
            <li><strong>編輯資料</strong>：可以新增、修改專案、發票、收款等資料</li>
            <li><strong>刪除資料</strong>：可以刪除專案、發票、收款等資料</li>
          </ul>
        </div>
        <div class="col-md-6">
          <h6>系統管理權限：</h6>
          <ul>
            <li><strong>使用者管理</strong>：可以管理系統使用者</li>
            <li><strong>角色管理</strong>：可以管理角色和權限</li>
            <li><strong>系統設定</strong>：可以修改系統設定</li>
            <li><strong>備份還原</strong>：可以執行備份和還原操作</li>
          </ul>
        </div>
      </div>
      <div class="row mt-3">
        <div class="col-12">
          <h6>專案檢視權限：</h6>
          <ul>
            <li><strong>檢視所有專案</strong>：可以查看系統中的所有專案</li>
            <li><strong>檢視自己的專案</strong>：只能查看自己負責的專案（需綁定業務員）</li>
          </ul>
        </div>
      </div>
    </div>
  </div>
</div>

<script>
function deleteRole(roleId, roleName) {
  if (!confirm('確定要刪除角色「' + roleName + '」嗎？\\n\\n刪除後角色將被停用，但不會永久刪除。')) {
    return;
  }

  fetch('/roles/' + roleId, {
    method: 'DELETE',
    headers: {
      'Content-Type': 'application/json'
    }
  })
  .then(response => response.json())
  .then(data => {
    if (data.success) {
      window.location.href = '/roles?success=' + encodeURIComponent(data.message);
    } else {
      alert('刪除失敗：' + (data.error || '未知錯誤'));
    }
  })
  .catch(err => {
    console.error('刪除角色錯誤:', err);
    alert('刪除失敗：' + err.message);
  });
}
</script>
` }) %>
