<%- include('../layout', { body: `
<div class="row mb-4">
  <div class="col">
    <h1 class="h3"><i class="bi bi-search"></i> 全域搜尋</h1>
  </div>
</div>

<div class="card mb-4">
  <div class="card-body">
    <form method="get" action="/search" class="d-flex gap-2">
      <div class="flex-grow-1">
        <input type="text" name="q" class="form-control form-control-lg" placeholder="搜尋專案編號、專案名稱、客戶、發票號碼..." value="${typeof q !== 'undefined' ? (q || '').replace(/"/g, '&quot;') : ''}" autofocus>
      </div>
      <button type="submit" class="btn btn-primary btn-lg">
        <i class="bi bi-search"></i> 搜尋
      </button>
    </form>
  </div>
</div>

${typeof message !== 'undefined' && message ? `
<div class="alert alert-info">
  <i class="bi bi-info-circle"></i> ${message}
</div>
` : ''}

${typeof q !== 'undefined' && q && !message ? `
<div class="row g-4">
  ${projects.length > 0 ? `
  <div class="col-12">
    <div class="card">
      <div class="card-header">
        <i class="bi bi-folder"></i> 專案 (${projects.length})
      </div>
      <div class="card-body p-0">
        <div class="table-responsive">
          <table class="table table-hover mb-0">
            <thead class="table-light">
              <tr>
                <th>專案編號</th>
                <th>專案名稱</th>
                <th>類型</th>
                <th>業務</th>
                <th class="text-end">金額</th>
                <th>狀態</th>
                <th></th>
              </tr>
            </thead>
            <tbody>
              ${projects.map(p => { const tc = typeof typeColorMap !== 'undefined' && typeColorMap[p.project_type] ? typeColorMap[p.project_type] : 'info'; return '<tr><td><code>' + p.project_code + '</code></td><td>' + p.project_name + '</td><td><span class="badge bg-' + tc + '">' + (p.project_type || '-') + '</span></td><td>' + (p.salesperson_name || '-') + '</td><td class="text-end">$' + (p.price_with_tax || 0).toLocaleString() + '</td><td><span class="badge bg-' + (p.status === '已結案' ? 'secondary' : 'warning') + '">' + (p.status || '-') + '</span></td><td><a href="/projects/' + p.id + '" class="btn btn-sm btn-outline-primary">查看</a></td></tr>'; }).join('')}
            </tbody>
          </table>
        </div>
      </div>
    </div>
  </div>
  ` : ''}

  ${customers.length > 0 ? `
  <div class="col-12">
    <div class="card">
      <div class="card-header">
        <i class="bi bi-building"></i> 客戶 (${customers.length})
      </div>
      <div class="card-body p-0">
        <div class="table-responsive">
          <table class="table table-hover mb-0">
            <thead class="table-light">
              <tr>
                <th>客戶編號</th>
                <th>公司名稱</th>
                <th>統編</th>
                <th></th>
              </tr>
            </thead>
            <tbody>
              ${customers.map(c => '<tr><td><code>' + c.customer_code + '</code></td><td>' + c.company_name + '</td><td>' + (c.tax_id || '-') + '</td><td><a href="/customers/' + c.id + '" class="btn btn-sm btn-outline-primary">查看</a></td></tr>').join('')}
            </tbody>
          </table>
        </div>
      </div>
    </div>
  </div>
  ` : ''}

  ${invoices.length > 0 ? `
  <div class="col-12">
    <div class="card">
      <div class="card-header">
        <i class="bi bi-receipt"></i> 發票 (${invoices.length})
      </div>
      <div class="card-body p-0">
        <div class="table-responsive">
          <table class="table table-hover mb-0">
            <thead class="table-light">
              <tr>
                <th>發票號碼</th>
                <th>專案</th>
                <th>日期</th>
                <th class="text-end">金額</th>
                <th></th>
              </tr>
            </thead>
            <tbody>
              ${invoices.map(i => '<tr><td><code>' + (i.invoice_number || '-') + '</code></td><td><code>' + i.project_code + '</code> ' + i.project_name + '</td><td>' + (i.invoice_date || '-') + '</td><td class="text-end">$' + (i.amount_with_tax || 0).toLocaleString() + '</td><td><a href="/projects/' + i.project_id + '" class="btn btn-sm btn-outline-primary">查看專案</a></td></tr>').join('')}
            </tbody>
          </table>
        </div>
      </div>
    </div>
  </div>
  ` : ''}

  ${projects.length === 0 && customers.length === 0 && invoices.length === 0 ? `
  <div class="col-12">
    <div class="alert alert-warning">
      <i class="bi bi-search"></i> 找不到符合「<strong>${q}</strong>」的結果，請嘗試其他關鍵字
    </div>
  </div>
  ` : ''}
</div>
` : ''}
` }) %>
