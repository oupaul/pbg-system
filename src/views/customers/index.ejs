<%
  // 組合篩選連結，保留其他已套用的篩選條件與搜尋關鍵字
  function buildFilterLink(overrides) {
    const merged = {
      search: (typeof searchKeyword !== 'undefined' ? searchKeyword : '') || '',
      status: (typeof statusFilter !== 'undefined' ? statusFilter : '') || '',
      party_type: (typeof partyTypeFilter !== 'undefined' ? partyTypeFilter : '') || '',
      vendor_type: (typeof vendorTypeFilter !== 'undefined' ? vendorTypeFilter : '') || '',
      ...overrides
    };
    const qs = Object.entries(merged)
      .filter(([, v]) => v)
      .map(([k, v]) => k + '=' + encodeURIComponent(v))
      .join('&');
    return '/customers' + (qs ? '?' + qs : '');
  }
%>
<%- include('../layout', { body: `
<div class="row mb-4">
  <div class="col">
    <h1 class="h3"><i class="bi bi-building"></i> 客戶與廠商管理</h1>
  </div>
  <div class="col-auto">
    ${locals.canEditCrm ? `
      <button class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#newCustomerModal">
        <i class="bi bi-plus-lg"></i> 新增客戶/廠商
      </button>
    ` : ''}
  </div>
</div>

${error ? `
  <div class="alert alert-danger alert-dismissible fade show" role="alert">
    <i class="bi bi-exclamation-triangle"></i> ${error}
    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
  </div>
` : ''}

${typeof success !== 'undefined' && success ? `
  <div class="alert alert-success alert-dismissible fade show" role="alert">
    <i class="bi bi-check-circle"></i> ${success}
    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
  </div>
` : ''}

<div class="mb-3 party-type-tree">
  <div class="tree-row">
    <a href="${buildFilterLink({ party_type: '', vendor_type: '' })}" class="btn btn-sm ${!partyTypeFilter ? 'btn-primary' : 'btn-outline-primary'}">全部類型</a>
  </div>
  <div class="tree-row">
    <a href="${buildFilterLink({ party_type: '客戶', vendor_type: '' })}" class="btn btn-sm ${partyTypeFilter === '客戶' ? 'btn-info' : 'btn-outline-info'}">客戶</a>
    <div class="vendor-col">
      <a href="${buildFilterLink({ party_type: '廠商', vendor_type: '' })}" class="btn btn-sm ${partyTypeFilter === '廠商' && !vendorTypeFilter ? 'btn-dark' : 'btn-outline-dark'}">廠商</a>
      <div class="tree-row">
        <a href="${buildFilterLink({ party_type: '廠商', vendor_type: '個人' })}" class="btn btn-sm ${partyTypeFilter === '廠商' && vendorTypeFilter === '個人' ? 'btn-secondary' : 'btn-outline-secondary'}">個人</a>
        <a href="${buildFilterLink({ party_type: '廠商', vendor_type: '公司' })}" class="btn btn-sm ${partyTypeFilter === '廠商' && vendorTypeFilter === '公司' ? 'btn-secondary' : 'btn-outline-secondary'}">公司</a>
      </div>
    </div>
  </div>
</div>

<!-- 搜尋表單 -->
<div class="card mb-4">
  <div class="card-body">
    <form method="GET" action="/customers" class="row g-3">
      <div class="col-md-8">
        <div class="input-group">
          <span class="input-group-text"><i class="bi bi-search"></i></span>
          <input 
            type="text" 
            name="search" 
            class="form-control" 
            placeholder="搜尋客戶編號、統一編號或公司名稱..." 
            value="${(typeof searchKeyword !== 'undefined' ? searchKeyword : '') || ''}"
            autocomplete="off"
          >
        </div>
      </div>
      <div class="col-md-4">
        <div class="btn-group w-100" role="group">
          <button type="submit" class="btn btn-outline-primary">
            <i class="bi bi-search"></i> 搜尋
          </button>
          ${(typeof searchKeyword !== 'undefined' && searchKeyword) ? `
            <a href="/customers" class="btn btn-outline-secondary">
              <i class="bi bi-x-lg"></i> 清除
            </a>
          ` : ''}
        </div>
      </div>
      ${(typeof searchKeyword !== 'undefined' && searchKeyword && req && req.query) ? `
        <input type="hidden" name="sortBy" value="${req.query.sortBy || 'company_name'}">
        <input type="hidden" name="sortOrder" value="${req.query.sortOrder || 'ASC'}">
      ` : ''}
      ${statusFilter ? '<input type="hidden" name="status" value="' + statusFilter + '">' : ''}
      ${partyTypeFilter ? '<input type="hidden" name="party_type" value="' + partyTypeFilter + '">' : ''}
      ${vendorTypeFilter ? '<input type="hidden" name="vendor_type" value="' + vendorTypeFilter + '">' : ''}
    </form>
  </div>
</div>

<div class="card">
  <div class="card-body p-0">
    <div class="table-responsive">
      <table class="table table-hover mb-0">
        <thead class="table-dark">
          <tr>
            <th>
              <a href="?${(sortLinks && sortLinks.customer_code) || ''}" class="text-white text-decoration-none">
                客戶編號${(sortIcons && sortIcons.customer_code) || ''}
              </a>
            </th>
            <th>
              <a href="?${(sortLinks && sortLinks.tax_id) || ''}" class="text-white text-decoration-none">
                統一編號${(sortIcons && sortIcons.tax_id) || ''}
              </a>
            </th>
            <th style="white-space: nowrap;">
              <a href="?${(sortLinks && sortLinks.company_name) || ''}" class="text-white text-decoration-none">
                公司名稱${(sortIcons && sortIcons.company_name) || ''}
              </a>
            </th>
            <th class="text-center">
              <a href="?${(sortLinks && sortLinks.project_count) || ''}" class="text-white text-decoration-none">
                專案數${(sortIcons && sortIcons.project_count) || ''}
              </a>
            </th>
            <th class="text-end">
              <a href="?${(sortLinks && sortLinks.total_project_amount) || ''}" class="text-white text-decoration-none">
                專案金額${(sortIcons && sortIcons.total_project_amount) || ''}
              </a>
            </th>
            <th>
              <a href="?${(sortLinks && sortLinks.party_type) || ''}" class="text-white text-decoration-none">
                類型${(sortIcons && sortIcons.party_type) || ''}
              </a>
            </th>
            <th>
              <a href="?${(sortLinks && sortLinks.owner_salesperson_name) || ''}" class="text-white text-decoration-none">
                客戶關係負責人${(sortIcons && sortIcons.owner_salesperson_name) || ''}
              </a>
            </th>
            <th>
              <a href="?${(sortLinks && sortLinks.salesperson_names) || ''}" class="text-white text-decoration-none">
                所屬業務人員${(sortIcons && sortIcons.salesperson_names) || ''}
              </a>
            </th>
            <th class="text-center">
              <a href="?${(sortLinks && sortLinks.customer_level) || ''}" class="text-white text-decoration-none">
                等級${(sortIcons && sortIcons.customer_level) || ''}
              </a>
            </th>
            <th>
              <a href="?${(sortLinks && sortLinks.status) || ''}" class="text-white text-decoration-none">
                狀態${(sortIcons && sortIcons.status) || ''}
              </a>
            </th>
          </tr>
        </thead>
        <tbody>
          ${(!customers || customers.length === 0) ? `
            <tr>
              <td colspan="10" class="text-center text-muted py-3">
                ${(typeof searchKeyword !== 'undefined' && searchKeyword) ? `找不到符合「<strong>${searchKeyword}</strong>」的客戶` : '尚無客戶'}
              </td>
            </tr>
          ` : (customers || []).map(c => `
            <tr onclick="location.href='/customers/${c.id}'" style="cursor:pointer">
              <td><code>${c.customer_code || ''}</code></td>
              <td>${c.tax_id || '-'}</td>
              <td style="white-space: nowrap;"><strong>${c.company_name || ''}</strong></td>
              <td class="text-center">${c.project_count || 0}</td>
              <td class="text-end">$${(c.total_project_amount || 0).toLocaleString()}</td>
              <td>
                <span class="badge bg-${c.party_type === '廠商' ? 'dark' : c.party_type === '兩者皆是' ? 'primary' : 'info'}">${c.party_type || '客戶'}</span>
                ${c.vendor_type ? '<span class="badge bg-secondary">' + c.vendor_type + '</span>' : ''}
              </td>
              <td>${c.owner_salesperson_name || '-'}</td>
              <td>${c.salesperson_names || '-'}</td>
              <td class="text-center">${c.customer_level ? '<span class="badge bg-' + (c.customer_level === 'A' ? 'success' : c.customer_level === 'B' ? 'warning' : 'secondary') + '">' + c.customer_level + '</span>' : '-'}</td>
              <td><span class="badge bg-${c.status === '往來中' ? 'success' : c.status === '暫停往來' ? 'warning' : 'secondary'}">${c.status || '往來中'}</span></td>
            </tr>
          `).join('')}
        </tbody>
      </table>
    </div>
  </div>
  <div class="card-footer text-muted">
    ${(typeof searchKeyword !== 'undefined' && searchKeyword) ? `搜尋「<strong>${searchKeyword}</strong>」結果：共 ${(customers || []).length} 筆` : `共 ${(customers || []).length} 筆`}
  </div>
</div>

<!-- 新增客戶 Modal -->
<div class="modal fade" id="newCustomerModal" tabindex="-1">
  <div class="modal-dialog">
    <div class="modal-content">
      <form action="/customers" method="POST">
        <div class="modal-header">
          <h5 class="modal-title">新增客戶/廠商</h5>
          <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
        </div>
        <div class="modal-body">
          <div class="mb-3">
            <label class="form-label">類型 <span class="text-danger">*</span></label>
            <select name="party_type" class="form-select" id="newPartyType" onchange="document.getElementById('newVendorTypeWrap').style.display = (this.value === '客戶') ? 'none' : '';">
              <option value="客戶" selected>客戶</option>
              <option value="廠商">廠商</option>
              <option value="兩者皆是">兩者皆是（客戶+廠商）</option>
            </select>
          </div>
          <div class="mb-3" id="newVendorTypeWrap" style="display:none">
            <label class="form-label">廠商類型</label>
            <select name="vendor_type" class="form-select">
              <option value="">-- 選擇類型 --</option>
              <option value="個人">個人</option>
              <option value="公司">公司</option>
            </select>
          </div>
          <div class="mb-3">
            <label class="form-label">客戶編號</label>
            <input type="text" name="customer_code" class="form-control" required>
          </div>
          <div class="mb-3">
            <label class="form-label">統一編號</label>
            <input type="text" name="tax_id" class="form-control" maxlength="8">
          </div>
          <div class="mb-3">
            <label class="form-label">公司名稱</label>
            <input type="text" name="company_name" class="form-control" required>
          </div>
          <hr>
          <div class="mb-3">
            <label class="form-label">客戶關係負責人（使用者）</label>
            <select name="owner_salesperson_id" class="form-select">
              <option value="">-- 選擇使用者 --</option>
              ${(staffUsers || []).map(u => '<option value="' + u.id + '">' + (u.name || '').replace(/"/g, '&quot;') + '</option>').join('')}
            </select>
          </div>
          <div class="mb-3">
            <label class="form-label">聯絡人</label>
            <input type="text" name="contact_name" class="form-control">
          </div>
          <div class="row g-2">
            <div class="col-md-6 mb-3">
              <label class="form-label">聯絡電話</label>
              <input type="text" name="contact_phone" class="form-control">
            </div>
            <div class="col-md-6 mb-3">
              <label class="form-label">聯絡信箱</label>
              <input type="email" name="contact_email" class="form-control">
            </div>
          </div>
          <div class="row g-2">
            <div class="col-md-6 mb-3">
              <label class="form-label">銀行名稱</label>
              <input type="text" name="bank_name" class="form-control">
            </div>
            <div class="col-md-6 mb-3">
              <label class="form-label">銀行帳號</label>
              <input type="text" name="bank_account" class="form-control">
            </div>
          </div>
          <div class="mb-3">
            <label class="form-label">地址</label>
            <input type="text" name="address" class="form-control">
          </div>
          <hr>
          <div class="row g-2">
            <div class="col-md-4 mb-3">
              <label class="form-label">客戶等級</label>
              <select name="customer_level" class="form-select">
                <option value="">-- 未分級 --</option>
                <option value="A">A</option>
                <option value="B">B</option>
                <option value="C">C</option>
              </select>
            </div>
            <div class="col-md-4 mb-3">
              <label class="form-label">產業別</label>
              <input type="text" name="industry" class="form-control">
            </div>
            <div class="col-md-4 mb-3">
              <label class="form-label">往來狀態</label>
              <select name="status" class="form-select">
                <option value="往來中" selected>往來中</option>
                <option value="暫停往來">暫停往來</option>
                <option value="已流失">已流失</option>
              </select>
            </div>
          </div>
        </div>
        <div class="modal-footer">
          <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">取消</button>
          <button type="submit" class="btn btn-primary">新增</button>
        </div>
      </form>
    </div>
  </div>
</div>
`}) %>
