<%- include('../layout', { title: '修改記錄', body: `
<div class="d-flex justify-content-between align-items-center mb-4">
  <h2><i class="bi bi-clock-history"></i> 修改記錄</h2>
  <a href="/audit-logs/export${typeof queryString !== 'undefined' && queryString ? '?' + queryString : ''}" class="btn btn-outline-success"><i class="bi bi-download"></i> 匯出 CSV</a>
</div>

<!-- 篩選表單 -->
<div class="card mb-4">
  <div class="card-body">
    <form method="GET" action="/audit-logs" class="row g-3">
      <div class="col-md-3">
        <label class="form-label">資料表</label>
        <select name="table_name" class="form-select">
          <option value="">全部</option>
          ${tableNames.map(table => `
            <option value="${table}" ${filters.tableName === table ? 'selected' : ''}>${typeof tableLabels !== 'undefined' && tableLabels[table] ? tableLabels[table] : table}</option>
          `).join('')}
        </select>
      </div>
      <div class="col-md-2">
        <label class="form-label">操作類型</label>
        <select name="action" class="form-select">
          <option value="">全部</option>
          ${actions.map(action => `
            <option value="${action}" ${filters.action === action ? 'selected' : ''}>${typeof actionLabels !== 'undefined' && actionLabels[action] ? actionLabels[action] : action}</option>
          `).join('')}
        </select>
      </div>
      <div class="col-md-2">
        <label class="form-label">記錄ID</label>
        <input type="number" name="record_id" class="form-control" value="${filters.recordId || ''}" placeholder="記錄ID">
      </div>
      <div class="col-md-2">
        <label class="form-label">開始日期</label>
        <input type="date" name="start_date" class="form-control" value="${filters.startDate || ''}">
      </div>
      <div class="col-md-2">
        <label class="form-label">結束日期</label>
        <input type="date" name="end_date" class="form-control" value="${filters.endDate || ''}">
      </div>
      <div class="col-md-1 d-flex align-items-end">
        <button type="submit" class="btn btn-primary w-100">
          <i class="bi bi-search"></i> 搜尋
        </button>
      </div>
    </form>
  </div>
</div>

<!-- 記錄列表 -->
<div class="card">
  <div class="card-header d-flex justify-content-between align-items-center">
    <span>共 ${pagination.total} 筆記錄</span>
    <div>
      ${pagination.page > 1 ? `
        <a href="?${queryString ? queryString + '&' : ''}page=${pagination.page - 1}" class="btn btn-sm btn-outline-primary">
          <i class="bi bi-chevron-left"></i> 上一頁
        </a>
      ` : ''}
      <span class="mx-2">第 ${pagination.page} / ${pagination.totalPages} 頁</span>
      ${pagination.page < pagination.totalPages ? `
        <a href="?${queryString ? queryString + '&' : ''}page=${pagination.page + 1}" class="btn btn-sm btn-outline-primary">
          下一頁 <i class="bi bi-chevron-right"></i>
        </a>
      ` : ''}
    </div>
  </div>
  <div class="card-body p-0">
    ${logs.length === 0 ? `
      <div class="text-center py-5">
        <i class="bi bi-inbox" style="font-size: 3rem; color: #ccc;"></i>
        <p class="text-muted mt-3">尚無修改記錄</p>
      </div>
    ` : `
      <div class="table-responsive">
        <table class="table table-hover mb-0">
          <thead class="table-light">
            <tr>
              <th>時間</th>
              <th>操作</th>
              <th>資料表</th>
              <th>記錄ID</th>
              <th>修改內容</th>
              <th>使用者</th>
            </tr>
          </thead>
          <tbody>
            ${logs.map(log => `
              <tr>
                <td>${log.created_at}</td>
                <td>
                  ${log.action === 'create' ? `
                    <span class="badge bg-success">新增</span>
                  ` : log.action === 'update' ? `
                    <span class="badge bg-warning text-dark">更新</span>
                  ` : log.action === 'delete' ? `
                    <span class="badge bg-danger">刪除</span>
                  ` : ''}
                </td>
                <td><code>${typeof tableLabels !== 'undefined' && tableLabels[log.table_name] ? tableLabels[log.table_name] : log.table_name}</code></td>
                <td>${log.record_id}</td>
                <td>
                  ${log.action === 'create' && log.new_value_parsed ? `
                    <button class="btn btn-sm btn-outline-info" type="button" data-bs-toggle="collapse" data-bs-target="#new-${log.id}">
                      <i class="bi bi-eye"></i> 查看
                    </button>
                    <div class="collapse mt-2" id="new-${log.id}">
                      <pre class="bg-light p-2 rounded">${log.new_value_html || JSON.stringify(log.new_value_parsed, null, 2)}</pre>
                    </div>
                  ` : log.action === 'update' ? `
                    <button class="btn btn-sm btn-outline-info" type="button" data-bs-toggle="collapse" data-bs-target="#diff-${log.id}">
                      <i class="bi bi-arrow-left-right"></i> 查看變更
                    </button>
                    <div class="collapse mt-2" id="diff-${log.id}">
                      <div class="row">
                        <div class="col-md-6">
                          <strong>舊值：</strong>
                          <pre class="bg-light p-2 rounded">${log.old_value_html || JSON.stringify(log.old_value_parsed, null, 2)}</pre>
                        </div>
                        <div class="col-md-6">
                          <strong>新值：</strong>
                          <pre class="bg-light p-2 rounded">${log.new_value_html || JSON.stringify(log.new_value_parsed, null, 2)}</pre>
                        </div>
                      </div>
                    </div>
                  ` : log.action === 'delete' && log.old_value_parsed ? `
                    <button class="btn btn-sm btn-outline-danger" type="button" data-bs-toggle="collapse" data-bs-target="#old-${log.id}">
                      <i class="bi bi-eye"></i> 查看
                    </button>
                    <div class="collapse mt-2" id="old-${log.id}">
                      <pre class="bg-light p-2 rounded">${log.old_value_html || JSON.stringify(log.old_value_parsed, null, 2)}</pre>
                    </div>
                  ` : ''}
                </td>
                <td>${log.user_info || '-'}</td>
              </tr>
            `).join('')}
          </tbody>
        </table>
      </div>
    `}
  </div>
</div>
` }) %>
