<%- include('../layout', { title: '專案範本', body: `
<div class="d-flex justify-content-between align-items-center mb-4">
  <h2><i class="bi bi-file-earmark-text"></i> 專案範本</h2>
  <a href="/project-templates/new" class="btn btn-primary"><i class="bi bi-plus-lg"></i> 新增範本</a>
</div>

${typeof success !== 'undefined' && success ? '<div class="alert alert-success alert-dismissible fade show"><i class="bi bi-check-circle"></i> ' + success + '<button type="button" class="btn-close" data-bs-dismiss="alert"></button></div>' : ''}
${typeof error !== 'undefined' && error ? '<div class="alert alert-danger alert-dismissible fade show"><i class="bi bi-exclamation-triangle"></i> ' + error + '<button type="button" class="btn-close" data-bs-dismiss="alert"></button></div>' : ''}

<div class="card">
  <div class="card-body p-0">
    ${(templates || []).length === 0 ? `
      <div class="text-center py-5 text-muted">
        <i class="bi bi-file-earmark-text" style="font-size: 3rem;"></i>
        <p class="mt-3">尚無專案範本</p>
        <a href="/project-templates/new" class="btn btn-primary">新增第一個範本</a>
      </div>
    ` : `
    <div class="table-responsive">
      <table class="table table-hover mb-0">
        <thead class="table-light">
          <tr>
            <th>範本名稱</th>
            <th>類型</th>
            <th>業務</th>
            <th>客戶</th>
            <th class="text-end">金額(含稅)</th>
            <th></th>
          </tr>
        </thead>
        <tbody>
          ${templates.map(t => `
            <tr>
              <td><strong>${(t.name || '').replace(/</g, '&lt;')}</strong>${t.description ? '<br><small class="text-muted">' + (t.description || '').replace(/</g, '&lt;') + '</small>' : ''}</td>
              <td>${t.project_type || '-'}</td>
              <td>${t.salesperson_name || '-'}</td>
              <td>${t.customer_name || '-'}</td>
              <td class="text-end">$${(t.price_with_tax || 0).toLocaleString()}</td>
              <td class="text-end">
                <a href="/projects/new?from_template=${t.id}" class="btn btn-sm btn-success"><i class="bi bi-plus-circle"></i> 從此建立專案</a>
                <a href="/project-templates/${t.id}/edit" class="btn btn-sm btn-outline-primary"><i class="bi bi-pencil"></i></a>
                <form action="/project-templates/${t.id}/delete" method="POST" style="display:inline" onsubmit="return confirm('確定刪除此範本？');">
                  <button type="submit" class="btn btn-sm btn-outline-danger"><i class="bi bi-trash"></i></button>
                </form>
              </td>
            </tr>
          `).join('')}
        </tbody>
      </table>
    </div>
    `}
  </div>
</div>
` }) %>
