            <small class="text-muted">獎金類型無法修改</small>
          </div>
          <div class="mb-3">
            <label class="form-label">計算基礎(未稅)</label>
            <input type="number" name="base_amount" class="form-control" value="${b.base_amount || 0}">
          </div>
          <div class="mb-3">
            <label class="form-label">獎金比例(%)</label>
            <input type="number" name="bonus_percentage" class="form-control" value="${b.bonus_percentage || 0}" step="0.1">
          </div>
          <div class="mb-3">
            <label class="form-label">獎金金額</label>
            <input type="number" name="bonus_amount" class="form-control" value="${b.bonus_amount || 0}" required>
          </div>
          <div class="mb-3">
            <label class="form-label">發放日期</label>
            <input type="date" name="payment_date" class="form-control" value="${b.payment_date || ''}">
          </div>
          <div class="mb-3">
            <label class="form-label">狀態</label>
            <select name="status" class="form-select">
              <option value="待發放" ${b.status === '待發放' ? 'selected' : ''}>待發放</option>
              <option value="已發放" ${b.status === '已發放' ? 'selected' : ''}>已發放</option>
              <option value="充公" ${b.status === '充公' ? 'selected' : ''}>充公</option>
            </select>
          </div>
          <div class="mb-3">
            <label class="form-label">充公原因</label>
            <textarea name="forfeiture_reason" class="form-control" rows="2">${b.forfeiture_reason || ''}</textarea>
            <small class="text-muted">僅在狀態為「充公」時填寫</small>
          </div>
        </div>
        <div class="modal-footer">
          <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">取消</button>
          <button type="submit" class="btn btn-info">更新</button>
        </div>
      </form>
    </div>
  </div>
</div>
`).join('')}
` : ''}
`}) %>
