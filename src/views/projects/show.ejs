            <input type="number" name="bank_deposit_amount" class="form-control" value="${pay.bank_deposit_amount || 0}" required>
          </div>
          <div class="mb-3">
            <label class="form-label">差異金額(匯費/違約金)</label>
            <input type="number" name="payment_difference" class="form-control" value="${pay.payment_difference || 0}">
          </div>
          <div class="mb-3">
            <label class="form-label">差異類型</label>
            <select name="difference_type" class="form-select">
              <option value="">-- 無 --</option>
              <option value="匯費" ${pay.difference_type === '匯費' ? 'selected' : ''}>匯費</option>
              <option value="違約金" ${pay.difference_type === '違約金' ? 'selected' : ''}>違約金</option>
              <option value="其他" ${pay.difference_type === '其他' ? 'selected' : ''}>其他</option>
            </select>
          </div>
          <div class="mb-3">
            <label class="form-label">備註</label>
            <textarea name="notes" class="form-control" rows="2">${pay.notes || ''}</textarea>
          </div>
        </div>
        <div class="modal-footer">
          <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">取消</button>
          <button type="submit" class="btn btn-success">更新</button>
        </div>
      </form>
    </div>
  </div>
</div>
`).join('')}

${locals.canEdit ? `
<!-- 編輯獎金 Modals -->
${bonuses.map(b => `
<div class="modal fade" id="editBonusModal${b.id}" tabindex="-1">
  <div class="modal-dialog">
    <div class="modal-content">
      <form action="/bonuses/${b.id}" method="POST">
        <input type="hidden" name="redirect" value="/projects/${project.id}">
