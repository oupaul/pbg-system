<%- include('../layout', { body: `
<div class="row mb-4">
  <div class="col">
    <nav aria-label="breadcrumb">
      <ol class="breadcrumb mb-0">
        <li class="breadcrumb-item"><a href="/projects">專案管理</a></li>
        <li class="breadcrumb-item active">${project.project_code}</li>
      </ol>
    </nav>
    <h1 class="h3 mt-2">${project.project_name}</h1>
  </div>
  ${locals.canEdit ? '<div class="col-auto"><a href="/projects/' + project.id + '/edit" class="btn btn-outline-primary"><i class="bi bi-pencil"></i> 編輯</a></div>' : ''}
</div>

${locals.isReadOnly ? '<div class="alert alert-info mb-4"><i class="bi bi-info-circle"></i> 您目前為唯讀模式，無法進行編輯操作</div>' : ''}
${typeof success !== 'undefined' && success ? '<div class="alert alert-success alert-dismissible fade show mb-4" role="alert"><i class="bi bi-check-circle"></i> ' + success + '<button type="button" class="btn-close" data-bs-dismiss="alert"></button></div>' : ''}
${typeof error !== 'undefined' && error ? '<div class="alert alert-danger alert-dismissible fade show mb-4" role="alert"><i class="bi bi-exclamation-triangle"></i> ' + error + '<button type="button" class="btn-close" data-bs-dismiss="alert"></button></div>' : ''}

<div class="row g-4 mb-4">
  <div class="col-md-8">
    <div class="card">
      <div class="card-header">
        <i class="bi bi-info-circle"></i> 專案資訊
      </div>
      <div class="card-body">
        <div class="row g-3">
          <div class="col-md-3">
            <label class="text-muted small">專案編號</label>
            <div><code class="fs-5">${project.project_code}</code></div>
          </div>
          <div class="col-md-3">
            <label class="text-muted small">專案類型</label>
            <div><span class="badge bg-${typeof typeColorMap !== 'undefined' && typeColorMap[project.project_type] ? typeColorMap[project.project_type] : (project.project_type === '食驗室' ? 'primary' : project.project_type === '純廣' ? 'success' : 'info')} fs-6">${project.project_type}</span></div>
          </div>
          <div class="col-md-3">
            <label class="text-muted small">狀態</label>
            <div><span class="badge bg-${project.status === '已結案' ? 'secondary' : project.status === '取消' ? 'danger' : 'warning'} fs-6">${project.status}</span></div>
          </div>
          <div class="col-md-3">
            <label class="text-muted small">合約</label>
            <div>
              ${locals.canEdit ? `
              <form action="/projects/${project.id}/attachments" method="POST" enctype="multipart/form-data" class="d-flex align-items-center gap-1 mb-2">
                <input type="file" name="file" class="form-control form-control-sm" style="max-width:8rem" accept="*/*" required>
                <button type="submit" class="btn btn-sm btn-outline-primary" title="上傳"><i class="bi bi-upload"></i></button>
              </form>
              ` : ''}
              ${typeof attachments !== 'undefined' && attachments.length ? `
              <ul class="list-unstyled mb-0 small">
                ${attachments.map(a => {
                  const isDeleted = !!a.deleted_at;
                  const fullName = (a.original_filename || '').replace(/</g, '&lt;');
                  const displayName = fullName.length > 18 ? fullName.substring(0, 18) + '…' : fullName;
                  const isPDF = (a.mime_type === 'application/pdf') || (fullName.toLowerCase().endsWith('.pdf'));
                  const linkTarget = isPDF ? ' target="_blank"' : '';
                  const link = isDeleted ? '<span class="text-muted">' + displayName + '</span>' : '<a href="/projects/' + project.id + '/attachments/' + a.id + '/download" class="text-decoration-none"' + linkTarget + ' title="' + fullName + '">' + displayName + '</a>';
                  const badge = isDeleted ? ' <span class="badge bg-secondary">已刪</span>' : '';
                  const actions = isDeleted
                    ? (locals.canEdit ? ' <form action="/projects/' + project.id + '/attachments/' + a.id + '/restore" method="POST" style="display:inline"><button type="submit" class="btn btn-sm btn-link p-0 text-success" title="還原"><i class="bi bi-arrow-counterclockwise"></i></button></form>' : '')
                    : (locals.canEdit ? ' <form action="/projects/' + project.id + '/attachments/' + a.id + '/delete" method="POST" style="display:inline" onsubmit="return confirm(\'確定刪除？\')"><button type="submit" class="btn btn-sm btn-link p-0 text-danger" title="刪除"><i class="bi bi-trash"></i></button></form>' : '');
                  return '<li class="d-flex align-items-center gap-1 flex-wrap">' + link + badge + actions + '</li>';
                }).join('')}
              </ul>
              ` : '<span class="text-muted">尚無</span>'}
            </div>
          </div>
          <div class="col-md-4">
            <label class="text-muted small">簽約年度/月份</label>
            <div class="fw-bold">${project.contract_year} / ${project.contract_month || '-'}月</div>
          </div>
          <div class="col-md-4">
            <label class="text-muted small">業務人員</label>
            <div class="fw-bold">${project.salesperson_name || '-'}</div>
          </div>
          <div class="col-md-4">
            <label class="text-muted small">新/舊客戶</label>
            <div>${project.is_new_customer ? '<span class="badge bg-success">新客戶</span>' : '<span class="badge bg-secondary">舊客戶</span>'}</div>
          </div>
          <div class="col-12">
            <label class="text-muted small">客戶</label>
            <div class="fw-bold">${project.company_name || '-'} <small class="text-muted">(${project.customer_code || '-'} / ${project.tax_id || '-'})</small></div>
          </div>
        </div>
      </div>
    </div>
  </div>
  
  <div class="col-md-4">
    <div class="card bg-light">
      <div class="card-header">
        <i class="bi bi-calculator"></i> 金額彙總
      </div>
      <div class="card-body">
        <div class="d-flex justify-content-between mb-2">
          <span>價格(含稅)</span>
          <strong>$${(project.price_with_tax || 0).toLocaleString()}</strong>
        </div>
        <div class="d-flex justify-content-between mb-2">
          <span>價格(未稅)</span>
          <span>$${(project.price_without_tax || 0).toLocaleString()}</span>
        </div>
        ${typeof project.sales_discount !== 'undefined' && project.sales_discount ? `
        <div class="d-flex justify-content-between mb-2">
          <span>銷貨折讓</span>
          <span class="text-warning">-$${(project.sales_discount || 0).toLocaleString()}</span>
        </div>
        ` : ''}
        ${typeof summary.totalCost !== 'undefined' ? `
        <div class="d-flex justify-content-between mb-2">
          <span>總成本</span>
          <span class="text-danger">$${(summary.totalCost || 0).toLocaleString()}</span>
        </div>
        ` : ''}
        ${typeof summary.grossProfit !== 'undefined' ? `
        <div class="d-flex justify-content-between mb-2">
          <span>未稅毛利</span>
          <strong class="${summary.grossProfit >= 0 ? 'text-success' : 'text-danger'}">$${(summary.grossProfit || 0).toLocaleString()}</strong>
        </div>
        ` : ''}
        <hr>
        <div class="d-flex justify-content-between mb-2">
          <span>已開發票</span>
          <span class="text-success">$${(summary.totalInvoiced || 0).toLocaleString()}</span>
        </div>
        <div class="d-flex justify-content-between mb-2">
          <span>未開發票</span>
          <span class="text-warning">$${(summary.uninvoiced || 0).toLocaleString()}</span>
        </div>
        <hr>
        <div class="d-flex justify-content-between mb-2">
          <span>已收款</span>
          <span class="text-success">$${(summary.totalReceived || 0).toLocaleString()}</span>
        </div>
        <div class="d-flex justify-content-between mb-2">
          <span>應收帳款</span>
          <span class="text-danger">$${(summary.outstanding || 0).toLocaleString()}</span>
        </div>
        ${locals.user && (locals.user.role === 'admin' || locals.user.role === 'user') ? `
        <hr>
        <div class="d-flex justify-content-between">
          <span>獎金合計</span>
          <strong class="text-primary">$${(summary.totalBonus || 0).toLocaleString()}</strong>
        </div>
        ` : ''}
      </div>
    </div>
  </div>
</div>

<!-- 業務預計開立發票年月 -->
${locals.canEdit ? `
<div class="card mb-3 border-primary">
  <div class="card-body py-2">
    <form id="expectedInvoiceForm" action="/projects/${project.id}/update-expected-invoice" method="POST" class="row g-2 align-items-center" onsubmit="return validateExpectedInvoiceForm()">
      <div class="col-auto">
        <label class="col-form-label"><i class="bi bi-calendar-event text-primary"></i> <strong>業務預計開立發票年月：</strong></label>
      </div>
      <div class="col-auto">
        <select class="form-select form-select-sm" id="expectedYear" style="width: 100px;" onchange="updateExpectedInvoiceField()">
          <option value="">--年--</option>
          ${(() => {
            const currentYear = new Date().getFullYear();
            const selectedYearMonth = project.expected_invoice_year_month || '';
            const selectedYear = selectedYearMonth ? selectedYearMonth.split('-')[0] : '';
            let options = '';
            for (let y = currentYear - 1; y <= currentYear + 3; y++) {
              options += '<option value="' + y + '"' + (selectedYear == y ? ' selected' : '') + '>' + y + '年</option>';
            }
            return options;
          })()}
        </select>
      </div>
      <div class="col-auto">
        <select class="form-select form-select-sm" id="expectedMonth" style="width: 90px;" onchange="updateExpectedInvoiceField()">
          <option value="">--月--</option>
          ${(() => {
            const selectedYearMonth = project.expected_invoice_year_month || '';
            const selectedMonth = selectedYearMonth ? selectedYearMonth.split('-')[1] : '';
            let options = '';
            for (let m = 1; m <= 12; m++) {
              const monthStr = m.toString().padStart(2, '0');
              options += '<option value="' + monthStr + '"' + (selectedMonth == monthStr ? ' selected' : '') + '>' + m + '月</option>';
            }
            return options;
          })()}
        </select>
      </div>
      <input type="hidden" name="expected_invoice_year_month" id="expectedInvoiceYearMonth" value="${project.expected_invoice_year_month || ''}">
      <div class="col-auto">
        <button type="submit" class="btn btn-sm btn-primary"><i class="bi bi-check-lg"></i> 更新</button>
      </div>
      <div class="col-auto">
        <button type="button" class="btn btn-sm btn-outline-secondary" onclick="resetExpectedInvoice()" ${!project.expected_invoice_year_month ? 'disabled' : ''}>
          <i class="bi bi-x-circle"></i> 重設
        </button>
      </div>
      <div class="col-auto">
        <span class="text-muted small">
          ${project.expected_invoice_year_month ? '已設定: <strong class="text-primary">' + project.expected_invoice_year_month + '</strong>' : '尚未設定'}
        </span>
      </div>
    </form>
  </div>
</div>

<script>
// 更新隱藏欄位的值
function updateExpectedInvoiceField() {
  const yearSelect = document.getElementById('expectedYear');
  const monthSelect = document.getElementById('expectedMonth');
  const hiddenField = document.getElementById('expectedInvoiceYearMonth');
  
  if (!yearSelect || !monthSelect || !hiddenField) {
    console.error('找不到表單元素');
    return;
  }
  
  const year = yearSelect.value;
  const month = monthSelect.value;
  
  console.log('updateExpectedInvoiceField - Year:', year, 'Month:', month);
  
  if (year && month) {
    const value = year + '-' + month;
    hiddenField.value = value;
    console.log('設定 expected_invoice_year_month:', value);
  } else {
    console.log('年月未完整選擇，保持原值:', hiddenField.value);
  }
}

// 表單提交前驗證並更新隱藏欄位
function validateExpectedInvoiceForm() {
  const yearSelect = document.getElementById('expectedYear');
  const monthSelect = document.getElementById('expectedMonth');
  const hiddenField = document.getElementById('expectedInvoiceYearMonth');
  
  if (!yearSelect || !monthSelect || !hiddenField) {
    console.error('找不到表單元素');
    return false;
  }
  
  const year = yearSelect.value;
  const month = monthSelect.value;
  
  console.log('表單提交 - Year:', year, 'Month:', month);
  
  // 確保隱藏欄位有最新的值
  if (year && month) {
    const value = year + '-' + month;
    hiddenField.value = value;
    console.log('提交前設定 expected_invoice_year_month:', value);
    return true;
  } else if (!year && !month) {
    // 兩者都為空，清空隱藏欄位（允許清除設定）
    hiddenField.value = '';
    console.log('提交前清空 expected_invoice_year_month');
    return true;
  } else {
    // 只選了年或月，不允許提交
    alert('請同時選擇年份和月份，或兩者都不選');
    return false;
  }
}

// 重設預計開票年月
function resetExpectedInvoice() {
  if (!confirm('確定要重設預計開票年月為「尚未設定」嗎？')) {
    return;
  }
  
  const yearSelect = document.getElementById('expectedYear');
  const monthSelect = document.getElementById('expectedMonth');
  const hiddenField = document.getElementById('expectedInvoiceYearMonth');
  
  if (!yearSelect || !monthSelect || !hiddenField) {
    console.error('找不到表單元素');
    return;
  }
  
  // 清空選擇
  yearSelect.value = '';
  monthSelect.value = '';
  hiddenField.value = '';
  
  // 提交表單
  const form = document.getElementById('expectedInvoiceForm');
  if (form) {
    form.submit();
  }
}
</script>
` : (project.expected_invoice_year_month ? `
<!-- 唯讀顯示 -->
<div class="card mb-3 border-info">
  <div class="card-body py-2">
    <div class="row g-2 align-items-center">
      <div class="col-auto">
        <label class="col-form-label"><i class="bi bi-calendar-event text-info"></i> <strong>業務預計開立發票年月：</strong></label>
      </div>
      <div class="col-auto">
        <strong class="text-primary">${project.expected_invoice_year_month}</strong>
      </div>
    </div>
  </div>
</div>
` : '')}

<!-- 發票明細（overflow-visible 讓「更多」下拉選單顯示在最上層） -->
<div class="card mb-4 overflow-visible">
  <div class="card-header d-flex justify-content-between align-items-center flex-wrap gap-2">
    <span><i class="bi bi-receipt"></i> 發票明細</span>
    <div class="d-flex align-items-center gap-2">
      ${typeof showDeleted !== 'undefined' ? (showDeleted ? '<a href="/projects/' + project.id + '" class="btn btn-sm btn-outline-secondary"><i class="bi bi-eye-slash"></i> 隱藏已刪除</a>' : '<a href="/projects/' + project.id + '?show_deleted=1" class="btn btn-sm btn-outline-secondary"><i class="bi bi-eye"></i> 顯示已刪除</a>') : ''}
      ${locals.canEdit ? '<button class="btn btn-sm btn-primary" data-bs-toggle="modal" data-bs-target="#invoiceModal"><i class="bi bi-plus-lg"></i> 新增發票</button>' : ''}
    </div>
  </div>
  <div class="card-body p-0 overflow-visible">
    <div class="table-responsive invoice-table-responsive">
      <table class="table table-hover mb-0">
        <thead class="table-light">
          <tr>
            <th>狀態</th>
            <th>發票日期</th>
            <th>發票號碼</th>
            <th>預計收款日</th>
            <th class="text-end">金額(含稅)</th>
            <th>收款狀態</th>
            <th></th>
          </tr>
        </thead>
        <tbody>
          ${invoices.length ? invoices.map(inv => {
            const isValid = !inv.status || inv.status === '有效';
            const isDeleted = !!inv.deleted_at;
            const statusBadge = inv.status === '作廢' ? '<span class="badge bg-secondary">作廢</span>' : inv.status === '整筆折讓' ? '<span class="badge bg-warning text-dark">整筆折讓</span>' : '<span class="badge bg-success">有效</span>';
            const deletedBadge = isDeleted ? ' <span class="badge bg-secondary">已刪除</span>' : '';
            const replacementInv = inv.replacement_invoice_id ? invoices.find(i => i.id === inv.replacement_invoice_id) : null;
            const replacementLink = replacementInv ? ' <a href="#inv' + replacementInv.id + '" class="small">→ 重開 ' + (replacementInv.invoice_number || '#' + replacementInv.id) + '</a>' : '';
            const rowClass = isDeleted ? 'table-secondary' : (isValid ? '' : 'table-secondary');
            const actionCell = isDeleted
              ? (locals.canEdit ? '<form action="/invoices/' + inv.id + '/restore" method="POST" style="display:inline"><button type="submit" class="btn btn-sm btn-outline-success"><i class="bi bi-arrow-counterclockwise"></i> 還原</button></form>' : '')
              : (locals.canEdit && isValid ? '<button class="btn btn-sm btn-outline-primary me-1" data-bs-toggle="modal" data-bs-target="#editInvoiceModal' + inv.id + '"><i class="bi bi-pencil"></i></button>' : '') + (locals.canEdit && isValid ? '<div class="btn-group dropdown" data-bs-boundary="viewport" data-bs-popper-config="{\"strategy\":\"fixed\"}"><button type="button" class="btn btn-sm btn-outline-secondary dropdown-toggle" data-bs-toggle="dropdown">更多</button><ul class="dropdown-menu dropdown-menu-invoice dropdown-menu-end"><li><a class="dropdown-item" href="#" data-bs-toggle="modal" data-bs-target="#voidModal' + inv.id + '"><i class="bi bi-x-circle me-1"></i>作廢</a></li><li><a class="dropdown-item" href="#" data-bs-toggle="modal" data-bs-target="#voidReissueModal' + inv.id + '"><i class="bi bi-arrow-repeat me-1"></i>作廢重開</a></li><li><a class="dropdown-item" href="#" data-bs-toggle="modal" data-bs-target="#partialAllowanceModal' + inv.id + '"><i class="bi bi-percent me-1"></i>部分折讓</a></li><li><a class="dropdown-item" href="#" data-bs-toggle="modal" data-bs-target="#allowanceModal' + inv.id + '"><i class="bi bi-dash-circle me-1"></i>整筆折讓</a></li></ul></div>' : '') + (locals.canEdit ? '<form action="/invoices/' + inv.id + '/delete" method="POST" style="display:inline" onsubmit="return confirm(\'確定刪除？\')"><button type="submit" class="btn btn-sm btn-outline-danger"><i class="bi bi-trash"></i></button></form>' : '');
            return `
            <tr class="${rowClass}" id="inv${inv.id}">
              <td>${statusBadge}${deletedBadge}${replacementLink}</td>
              <td>${inv.invoice_date || '-'}</td>
              <td><code>${inv.invoice_number || '-'}</code></td>
              <td>${inv.expected_payment_date || '-'}</td>
              <td class="text-end">$${(inv.amount_with_tax || 0).toLocaleString()}${(inv.allowance_amount || 0) > 0 ? ' <span class="text-muted small">折讓 $' + (inv.allowance_amount || 0).toLocaleString() + '，認列 $' + Math.max(0, (inv.amount_with_tax || 0) - (inv.allowance_amount || 0)).toLocaleString() + '</span>' : ''}</td>
              <td><span class="${typeof inv.paymentStatus !== 'undefined' ? inv.paymentStatus.class : 'text-muted'}">${typeof inv.paymentStatus !== 'undefined' ? inv.paymentStatus.text : '-'}</span></td>
              <td class="text-end">${actionCell}</td>
            </tr>
          `}).join('') : '<tr><td colspan="7" class="text-center text-muted py-3">尚無發票</td></tr>'}
        </tbody>
      </table>
    </div>
  </div>
</div>

${invoices.filter(inv => !inv.status || inv.status === '有效').map(inv => `
<!-- 作廢發票 Modal -->
<div class="modal fade" id="voidModal${inv.id}" tabindex="-1">
  <div class="modal-dialog">
    <div class="modal-content">
      <form action="/invoices/${inv.id}/void" method="POST">
        <div class="modal-header">
          <h5 class="modal-title">作廢發票</h5>
          <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
        </div>
        <div class="modal-body">
          <p class="text-muted">發票號碼：<code>${inv.invoice_number || '-'}</code>，金額：$${(inv.amount_with_tax || 0).toLocaleString()}</p>
          <div class="mb-3">
            <label class="form-label">作廢日期</label>
            <input type="date" name="voided_at" class="form-control" value="${new Date().toISOString().slice(0, 10)}">
          </div>
          <div class="mb-3">
            <label class="form-label">作廢原因（選填）</label>
            <input type="text" name="void_reason" class="form-control" placeholder="例如：開立錯誤">
          </div>
        </div>
        <div class="modal-footer">
          <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">取消</button>
          <button type="submit" class="btn btn-warning">確認作廢</button>
        </div>
      </form>
    </div>
  </div>
</div>

<!-- 作廢重開 Modal -->
<div class="modal fade" id="voidReissueModal${inv.id}" tabindex="-1">
  <div class="modal-dialog">
    <div class="modal-content">
      <form action="/invoices/${inv.id}/void-and-reissue" method="POST">
        <div class="modal-header">
          <h5 class="modal-title">作廢並重開</h5>
          <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
        </div>
        <div class="modal-body">
          <p class="text-muted">原發票：<code>${inv.invoice_number || '-'}</code>，金額：$${(inv.amount_with_tax || 0).toLocaleString()}</p>
          <div class="mb-3">
            <label class="form-label">作廢原因（選填）</label>
            <input type="text" name="void_reason" class="form-control" placeholder="例如：開立錯誤需重開">
          </div>
          <hr>
          <h6>新發票資料</h6>
          <div class="mb-3">
            <label class="form-label">發票日期</label>
            <input type="date" name="invoice_date" class="form-control" value="${inv.invoice_date || ''}" required>
          </div>
          <div class="mb-3">
            <label class="form-label">發票號碼</label>
            <input type="text" name="invoice_number" class="form-control" placeholder="XX12345678" required>
          </div>
          <div class="mb-3">
            <label class="form-label">預計收款日</label>
            <input type="date" name="expected_payment_date" class="form-control" value="${inv.expected_payment_date || ''}">
          </div>
          <div class="mb-3">
            <label class="form-label">金額(含稅)</label>
            <input type="number" name="amount_with_tax" class="form-control" value="${inv.amount_with_tax || 0}" required>
          </div>
        </div>
        <div class="modal-footer">
          <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">取消</button>
          <button type="submit" class="btn btn-primary">作廢並建立新發票</button>
        </div>
      </form>
    </div>
  </div>
</div>

<!-- 部分折讓 Modal -->
<div class="modal fade" id="partialAllowanceModal${inv.id}" tabindex="-1">
  <div class="modal-dialog">
    <div class="modal-content">
      <form action="/invoices/${inv.id}/partial-allowance" method="POST">
        <div class="modal-header">
          <h5 class="modal-title">部分折讓</h5>
          <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
