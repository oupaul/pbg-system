            ${paymentReminder.overdue.map(item => '<tr class="table-danger"><td><code>' + item.project_code + '</code> ' + (item.project_name || '') + '</td><td><code>' + (item.invoice_number || '-') + '</code></td><td>' + item.salesperson_name + '</td><td class="text-end">$' + (item.unpaid || 0).toLocaleString() + '</td><td>' + (item.expected_payment_date || '-') + '</td><td><span class="badge bg-danger">已逾期</span></td><td><a href="/projects/' + item.project_id + '" class="btn btn-sm btn-outline-primary">查看</a></td></tr>').join('')}
