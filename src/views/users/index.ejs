<%- include('../layout', { title: '使用者管理', body: `
<div class="d-flex justify-content-between align-items-center mb-4">
  <h2><i class="bi bi-people"></i> 使用者管理</h2>
  <a href="/users/new" class="btn btn-primary">
    <i class="bi bi-person-plus"></i> 新增使用者
  </a>
</div>

${error ? `
  <div class="alert alert-danger alert-dismissible fade show" role="alert">
    <i class="bi bi-exclamation-triangle"></i> ${error}
    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
  </div>
` : ''}

${success ? `
  <div class="alert alert-success alert-dismissible fade show" role="alert">
    <i class="bi bi-check-circle"></i> ${success}
    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
  </div>
` : ''}

<div class="card">
  <div class="card-body p-0">
    ${users.length === 0 ? `
      <div class="text-center py-5">
        <i class="bi bi-inbox" style="font-size: 3rem; color: #ccc;"></i>
        <p class="text-muted mt-3">尚無使用者</p>
      </div>
    ` : `
      <div class="table-responsive">
        <table class="table table-hover mb-0">
          <thead class="table-light">
            <tr>
              <th>ID</th>
              <th>使用者名稱</th>
              <th>姓名</th>
              <th>角色</th>
              <th>關聯業務員</th>
              <th>狀態</th>
              <th>建立時間</th>
              <th>最後登入</th>
              <th>操作</th>
            </tr>
          </thead>
          <tbody>
            ${users.map(user => `
              <tr>
                <td>${user.id}</td>
                <td><code>${user.username}</code></td>
                <td>${user.name}</td>
                <td>
                  ${(() => {
                    const roleName = typeof rolesMap !== 'undefined' && rolesMap[user.role] ? rolesMap[user.role] : user.role;
                    const badgeClass = user.role === 'admin' ? 'bg-danger' : 
                                      user.role === 'boss' ? 'bg-primary' :
                                      user.role === 'salesperson' ? 'bg-info' :
                                      user.role === 'user' ? 'bg-secondary' : 'bg-dark';
                    return '<span class="badge ' + badgeClass + '">' + roleName + '</span>';
                  })()}
                </td>
                <td>
                  ${user.salesperson_name ? '<span class="badge bg-light text-dark">' + user.salesperson_name + '</span>' : '-'}
                </td>
                <td>
                  ${user.is_active ? `
                    <span class="badge bg-success">啟用</span>
                  ` : `
                    <span class="badge bg-secondary">停用</span>
                  `}
                </td>
                <td>${user.created_at || '-'}</td>
                <td>${user.last_login || '從未登入'}</td>
                <td>
                  <a href="/users/${user.id}/edit" class="btn btn-sm btn-outline-primary">
                    <i class="bi bi-pencil"></i> 編輯
                  </a>
                  ${user.id !== currentUserId ? `
                    <form method="POST" action="/users/${user.id}/toggle-active" class="d-inline ms-1" onsubmit="return confirm('確定要${user.is_active ? '停用' : '啟用'}此使用者嗎？');">
                      <button type="submit" class="btn btn-sm btn-outline-${user.is_active ? 'warning' : 'success'}">
                        <i class="bi bi-${user.is_active ? 'x-circle' : 'check-circle'}"></i> ${user.is_active ? '停用' : '啟用'}
                      </button>
                    </form>
                  ` : `
                    <span class="text-muted ms-2">（當前使用者）</span>
                  `}
                </td>
              </tr>
            `).join('')}
          </tbody>
        </table>
      </div>
    `}
  </div>
</div>
` }) %>

