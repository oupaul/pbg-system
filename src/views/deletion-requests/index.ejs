<%
  function escapeHtml(str) {
    return (str || '').toString().replace(/</g, '&lt;').replace(/>/g, '&gt;');
  }
%>
<%- include('../layout', { body: `
<div class="row mb-4">
  <div class="col">
    <h1 class="h3"><i class="bi bi-shield-check"></i> 刪除審核</h1>
    <p class="text-muted mb-0">業務員等無刪除權限的角色送出的刪除申請，需在此核准後才會真正刪除資料。</p>
  </div>
</div>

${error ? `
  <div class="alert alert-danger alert-dismissible fade show" role="alert">
    <i class="bi bi-exclamation-triangle"></i> ${escapeHtml(error)}
    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
  </div>
` : ''}

${success ? `
  <div class="alert alert-success alert-dismissible fade show" role="alert">
    <i class="bi bi-check-circle"></i> ${escapeHtml(success)}
    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
  </div>
` : ''}

<div class="card">
  <div class="card-body p-0">
    <div class="table-responsive">
      <table class="table table-hover mb-0">
        <thead class="table-dark">
          <tr>
            <th>類型</th>
            <th>內容摘要</th>
            <th>申請人</th>
            <th>申請時間</th>
            <th></th>
          </tr>
        </thead>
        <tbody>
          ${(requests || []).length === 0 ? `
            <tr><td colspan="5" class="text-center text-muted py-4">目前沒有待審核的刪除申請</td></tr>
          ` : requests.map(r => `
            <tr>
              <td><span class="badge bg-secondary">${targetLabels[r.target_type] || r.target_type}</span></td>
              <td>${r.target_link ? '<a href="' + r.target_link + '" target="_blank">' + (r.target_summary || '').replace(/</g, '&lt;').replace(/>/g, '&gt;') + ' <i class="bi bi-box-arrow-up-right small"></i></a>' : (r.target_summary || '').replace(/</g, '&lt;').replace(/>/g, '&gt;')}</td>
              <td>${r.requested_by_name || '-'}</td>
              <td>${r.requested_at}</td>
              <td class="text-end">
                <div class="d-flex gap-2 justify-content-end">
                  <form action="/deletion-requests/${r.id}/approve" method="POST" onsubmit="return confirm('確定要核准並刪除這筆資料嗎？')">
                    <button type="submit" class="btn btn-sm btn-success"><i class="bi bi-check-lg"></i> 核准刪除</button>
                  </form>
                  <button type="button" class="btn btn-sm btn-outline-secondary" data-bs-toggle="modal" data-bs-target="#rejectModal${r.id}">
                    <i class="bi bi-x-lg"></i> 駁回
                  </button>
                </div>
              </td>
            </tr>
          `).join('')}
        </tbody>
      </table>
    </div>
  </div>
</div>

${(requests || []).map(r => `
  <div class="modal fade" id="rejectModal${r.id}" tabindex="-1">
    <div class="modal-dialog">
      <div class="modal-content">
        <form action="/deletion-requests/${r.id}/reject" method="POST">
          <div class="modal-header">
            <h5 class="modal-title">駁回刪除申請</h5>
            <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
          </div>
          <div class="modal-body">
            <p class="mb-2">${(r.target_summary || '').replace(/</g, '&lt;').replace(/>/g, '&gt;')}</p>
            <label class="form-label">駁回原因（選填，會留給申請人參考）</label>
            <textarea name="review_note" class="form-control" rows="3"></textarea>
          </div>
          <div class="modal-footer">
            <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">取消</button>
            <button type="submit" class="btn btn-danger">確定駁回</button>
          </div>
        </form>
      </div>
    </div>
  </div>
`).join('')}
` }) %>
